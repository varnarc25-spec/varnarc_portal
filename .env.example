# Varnarc portal → deployed Marg API (Cloud Run). Do not point at local marg_api unless debugging.
MARG_API_BASE_URL=https://marg-api-548031081093.asia-south1.run.app

# Optional: use local marg_api instead (npm run in marg_api repo on port 3002)
# USE_LOCAL_MARG_API=1
# MARG_API_BASE_URL=http://localhost:3002

# Optional: longer upstream timeout (ms)
# MARG_HTTP_TIMEOUT_MS=120000

# Cache landing/menu API bundle in the portal process (default 300000 ms = 5 min).
# Set to 0 to disable. Reduces "Too many requests from this IP" on shared Cloud Run API.
# LANDING_BUNDLE_CACHE_TTL_MS=300000

# Optional: production session cookie
# NODE_ENV=production
# APP_SESSION_SECRET=change-me-in-production
