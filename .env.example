# Varnarc → Marg API (local dev: no Cloud Run rate limits)
# Default when NODE_ENV is not "production": http://localhost:3002
# Production deploy sets NODE_ENV=production → Cloud Run URL unless overridden.
MARG_API_BASE_URL=http://localhost:3002

# Optional: longer upstream timeout (ms)
# MARG_HTTP_TIMEOUT_MS=120000
