<% var slug = 'financial'; var href = hubHrefForPanel(slug); var active = panelIsActive(slug); %>
<div class="hub-tab-panel<%= active ? ' is-active' : '' %>" data-hub-panel="<%= slug %>" id="hub-panel-<%= slug %>" role="tabpanel"<%= active ? '' : ' hidden' %>>
  <h2 class="text-6 mb-4">Financial Services</h2>
  <form class="hub-service-form" action="<%= href %>" method="get">
    <p class="text-muted small mb-3">Manage investments and budgets securely on Varnarc.</p>
    <div class="mb-3">
      <label class="form-label" for="acct-financial">Account / Portfolio Id</label>
      <input type="text" class="form-control" id="acct-financial" placeholder="Enter account id" />
    </div>
    <div class="d-grid mt-4">
      <a class="btn btn-primary" href="<%= href %>">Continue</a>
    </div>
  </form>
</div>
