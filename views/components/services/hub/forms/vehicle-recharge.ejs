<%
  var slug = typeof panelSlug !== 'undefined' ? String(panelSlug) : 'fastag';
  var title = typeof panelTitle !== 'undefined' ? panelTitle : 'FASTag Recharge';
  var href = hubHrefForPanel(slug);
  var active = panelIsActive(slug);
%>
<div class="hub-tab-panel<%= active ? ' is-active' : '' %>" data-hub-panel="<%= slug %>" id="hub-panel-<%= slug %>" role="tabpanel"<%= active ? '' : ' hidden' %>>
  <h2 class="text-6 mb-4"><%= title %></h2>
  <form class="hub-service-form" action="<%= href %>" method="get">
    <div class="mb-3">
      <label class="form-label" for="op-<%= slug %>">Your Operator</label>
      <select class="form-select" id="op-<%= slug %>" required>
        <option value="" selected disabled>Select Your Operator</option>
        <option>NHAI FASTag</option><option>ICICI FASTag</option><option>Paytm FASTag</option>
      </select>
    </div>
    <div class="mb-3">
      <label class="form-label" for="veh-<%= slug %>">Vehicle Number</label>
      <input type="text" class="form-control" id="veh-<%= slug %>" placeholder="Enter Vehicle Number" required />
    </div>
    <%- include('./amount-field', { slug: slug, href: href, showPlans: true }) %>
    <div class="d-grid mt-4">
      <a class="btn btn-primary" href="<%= href %>">Continue to Recharge</a>
    </div>
  </form>
</div>
