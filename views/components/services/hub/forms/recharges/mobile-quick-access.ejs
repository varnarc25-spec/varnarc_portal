<section class="hub-quick-access" data-mobile-quick-access hidden aria-label="Quick access">
  <h3 class="hub-quick-access__title">Quick access</h3>
  <p class="hub-quick-access__lead">Signed-in users see recent numbers and quick recharge.</p>
  <div class="hub-quick-access__section" data-mr-quick-own hidden>
    <span class="hub-quick-access__label">Your number</span>
    <div class="hub-quick-access__pills">
      <button type="button" class="hub-quick-access__pill" data-mr-quick-own-btn data-quick-number="">
        Recharge my number
      </button>
    </div>
  </div>
  <div class="hub-quick-access__section">
    <span class="hub-quick-access__label">Recent recharges</span>
    <div class="hub-quick-access__pills" data-mr-quick-recent></div>
  </div>
  <div class="hub-quick-access__section">
    <span class="hub-quick-access__label">Saved numbers</span>
    <div class="hub-quick-access__pills" data-mr-quick-saved></div>
  </div>
</section>
