<% var pageTitle = 'FASTag Recharge Online'; %>
<% var pageDescription = 'Recharge FASTag online for supported banks and toll tag issuers on Varnarc.'; %>
<!DOCTYPE html>
<html lang="en">

<%- include('../../../components/landing/head') %>
<link rel="stylesheet" href="/assets/css/fastag-page.css" />

<body class="landing-page service-item-page">
  <div class="landing-page1">
    <div class="sticky-header"><%- include('../../../components/landing/header') %></div>
  </div>

  <section class="section-space service-item-section fastag-service-section">
    <div class="container text-start py-4">
      <div class="fastag-section-inner">
        <section class="fastag-card fastag-hero-card" aria-labelledby="fastag-page-heading">
          <div class="fastag-hero-card__icon" aria-hidden="true">
            <i class="bi bi-car-front-fill"></i>
          </div>
          <div>
            <h1 id="fastag-page-heading">FASTag Recharge Online</h1>
            <p>Recharge your FASTag quickly and keep your toll payments active while travelling.</p>
          </div>
        </section>

        <section class="fastag-card fastag-recharge-card" aria-labelledby="fastag-recharge-heading">
          <h2 id="fastag-recharge-heading">Recharge your FASTag</h2>
          <div class="fastag-form-grid">
            <label class="fastag-field">
              <span>Select a Service</span>
              <select aria-label="Select FASTag service">
                <option>FASTag Recharge</option>
              </select>
            </label>
            <label class="fastag-field">
              <span>Vehicle Number</span>
              <input type="text" placeholder="Enter vehicle number" autocomplete="off" />
            </label>
            <button type="button" class="fastag-primary-btn">Proceed</button>
          </div>
        </section>

        <section class="fastag-card" aria-labelledby="fastag-operators-heading">
          <h2 id="fastag-operators-heading">Top FASTag recharge operators</h2>
          <div class="fastag-operator-strip" role="list">
            <a href="#fastag-recharge-heading" class="fastag-operator" role="listitem">
              <span class="fastag-operator__logo fastag-operator__logo--sbi">SB</span>
              <span>SBI FASTag</span>
            </a>
            <a href="#fastag-recharge-heading" class="fastag-operator" role="listitem">
              <span class="fastag-operator__logo fastag-operator__logo--icici">IC</span>
              <span>ICICI FASTag</span>
            </a>
            <a href="#fastag-recharge-heading" class="fastag-operator" role="listitem">
              <span class="fastag-operator__logo fastag-operator__logo--hdfc">HD</span>
              <span>HDFC FASTag</span>
            </a>
            <a href="#fastag-recharge-heading" class="fastag-operator" role="listitem">
              <span class="fastag-operator__logo fastag-operator__logo--axis">AX</span>
              <span>Axis FASTag</span>
            </a>
            <a href="#fastag-recharge-heading" class="fastag-operator" role="listitem">
              <span class="fastag-operator__logo fastag-operator__logo--airtel">AT</span>
              <span>Airtel FASTag</span>
            </a>
            <a href="#fastag-recharge-heading" class="fastag-operator" role="listitem">
              <span class="fastag-operator__logo fastag-operator__logo--idfc">ID</span>
              <span>IDFC FASTag</span>
            </a>
            <a href="#fastag-recharge-heading" class="fastag-operator" role="listitem">
              <span class="fastag-operator__logo fastag-operator__logo--kotak">KO</span>
              <span>Kotak FASTag</span>
            </a>
          </div>
        </section>

        <section class="fastag-card fastag-content-card" aria-labelledby="fastag-about-heading">
          <h2 id="fastag-about-heading">FASTag recharge online on Varnarc</h2>
          <p>
            FASTag is a prepaid tag linked to your vehicle that enables automatic toll payments at National Highway toll plazas.
            Recharging online helps you avoid long queues, low-balance issues, and last-minute delays during travel.
          </p>
          <p>
            With Varnarc, you can select your FASTag issuer, enter the required vehicle or wallet details, and complete payment
            through supported digital payment methods.
          </p>
        </section>

        <section class="fastag-card fastag-content-card" aria-labelledby="fastag-steps-heading">
          <h2 id="fastag-steps-heading">How to make FASTag recharge online?</h2>
          <ol class="fastag-steps">
            <li>Select FASTag Recharge as the service.</li>
            <li>Choose your bank or FASTag issuer from the available operators.</li>
            <li>Enter the vehicle number, wallet ID, or customer ID as requested.</li>
            <li>Review the details and recharge amount before payment.</li>
            <li>Pay using UPI, card, wallet, or net banking and save the receipt.</li>
          </ol>
        </section>

        <section class="fastag-card fastag-content-card" aria-labelledby="fastag-benefits-heading">
          <h2 id="fastag-benefits-heading">Benefits of FASTag recharge online</h2>
          <ul class="fastag-check-list">
            <li>Recharge anytime without visiting a bank branch or toll plaza.</li>
            <li>Reduce waiting time at toll booths with active balance.</li>
            <li>Track payments with transaction IDs and digital receipts.</li>
            <li>Use supported digital payment modes for quick completion.</li>
            <li>Maintain sufficient balance before long-distance travel.</li>
          </ul>
        </section>

        <section class="fastag-card fastag-content-card" aria-labelledby="fastag-fees-heading">
          <div class="fastag-inline-heading">
            <h2 id="fastag-fees-heading">Fees and charges</h2>
            <span>Check before payment</span>
          </div>
          <p>
            Charges, minimum recharge amount, and processing timelines may vary based on the FASTag issuer. Always verify the
            biller details and recharge amount before confirming payment.
          </p>
        </section>

        <section class="fastag-card fastag-content-card" aria-labelledby="fastag-balance-heading">
          <h2 id="fastag-balance-heading">How can I check my FASTag balance?</h2>
          <p>
            You can check your FASTag balance through your issuing bank app, SMS alerts, issuer portal, or customer support.
            After a successful recharge, some issuers may take a short time to update balance across toll systems.
          </p>
        </section>

        <section class="fastag-card fastag-faq-card" aria-labelledby="fastag-faq-heading">
          <h2 id="fastag-faq-heading">Frequently asked questions</h2>
          <div class="accordion" id="fastagFaq">
            <div class="accordion-item">
              <h3 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#fastagFaq1" aria-expanded="false" aria-controls="fastagFaq1">
                  What details are required for FASTag recharge?
                </button>
              </h3>
              <div id="fastagFaq1" class="accordion-collapse collapse" data-bs-parent="#fastagFaq">
                <div class="accordion-body">
                  Most issuers ask for vehicle number, wallet ID, mobile number, or customer ID. The exact field depends on the issuing bank.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <h3 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#fastagFaq2" aria-expanded="false" aria-controls="fastagFaq2">
                  When will the recharge reflect in my FASTag?
                </button>
              </h3>
              <div id="fastagFaq2" class="accordion-collapse collapse" data-bs-parent="#fastagFaq">
                <div class="accordion-body">
                  Most successful recharges reflect within minutes. Some banks may take longer to sync the updated balance at toll plazas.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <h3 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#fastagFaq3" aria-expanded="false" aria-controls="fastagFaq3">
                  What should I do if money is debited but recharge is not updated?
                </button>
              </h3>
              <div id="fastagFaq3" class="accordion-collapse collapse" data-bs-parent="#fastagFaq">
                <div class="accordion-body">
                  Keep your transaction ID and payment receipt. If the balance is not updated after the expected window, raise a request with support.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <h3 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#fastagFaq4" aria-expanded="false" aria-controls="fastagFaq4">
                  Can I recharge FASTag for another vehicle?
                </button>
              </h3>
              <div id="fastagFaq4" class="accordion-collapse collapse" data-bs-parent="#fastagFaq">
                <div class="accordion-body">
                  Yes, if you have the correct vehicle number or FASTag account details accepted by the issuer.
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="fastag-card" aria-labelledby="fastag-articles-heading">
          <h2 id="fastag-articles-heading">Articles</h2>
          <div class="fastag-resource-grid">
            <a href="#!" class="fastag-resource-card">
              <span class="fastag-resource-card__thumb fastag-resource-card__thumb--road"></span>
              <span>How FASTag makes toll payments faster</span>
            </a>
            <a href="#!" class="fastag-resource-card">
              <span class="fastag-resource-card__thumb fastag-resource-card__thumb--wallet"></span>
              <span>Tips to maintain enough FASTag balance</span>
            </a>
            <a href="#!" class="fastag-resource-card">
              <span class="fastag-resource-card__thumb fastag-resource-card__thumb--car"></span>
              <span>Common FASTag recharge issues and fixes</span>
            </a>
          </div>
        </section>

        <section class="fastag-card" aria-labelledby="fastag-videos-heading">
          <h2 id="fastag-videos-heading">Videos</h2>
          <div class="fastag-video-grid">
            <a href="#!" class="fastag-video-card">
              <span class="fastag-video-card__thumb"><i class="bi bi-play-fill"></i></span>
              <span>How to recharge FASTag online</span>
            </a>
            <a href="#!" class="fastag-video-card">
              <span class="fastag-video-card__thumb fastag-video-card__thumb--blue"><i class="bi bi-play-fill"></i></span>
              <span>How to check FASTag balance</span>
            </a>
            <a href="#!" class="fastag-video-card">
              <span class="fastag-video-card__thumb fastag-video-card__thumb--purple"><i class="bi bi-play-fill"></i></span>
              <span>FASTag recharge safety tips</span>
            </a>
            <a href="#!" class="fastag-video-card">
              <span class="fastag-video-card__thumb fastag-video-card__thumb--teal"><i class="bi bi-play-fill"></i></span>
              <span>What to do when recharge is pending</span>
            </a>
          </div>
        </section>
      </div>
    </div>
  </section>

<%- include('../../../components/landing/footer') %>
<%- include('../../../components/landing/scripts') %>
</body>

</html>
