<%
  var slug = typeof panelSlug !== 'undefined' ? String(panelSlug) : 'insurance-bike';
  var title = typeof panelTitle !== 'undefined' ? panelTitle : 'Bike Insurance';
  var href = hubHrefForPanel(slug);
  var active = panelIsActive(slug);
%>
<div class="hub-tab-panel<%= active ? ' is-active' : '' %>" data-hub-panel="<%= slug %>" id="hub-panel-<%= slug %>" role="tabpanel"<%= active ? '' : ' hidden' %>>
  <h2 class="text-6 mb-4"><%= title %></h2>
  <form class="hub-service-form" action="<%= href %>" method="get">
    <div class="mb-3">
      <label class="form-label" for="veh-<%= slug %>">Vehicle / Policy Number</label>
      <input type="text" class="form-control" id="veh-<%= slug %>" placeholder="Enter details" required />
    </div>
    <div class="mb-3">
      <label class="form-label" for="op-<%= slug %>">Insurer</label>
      <select class="form-select" id="op-<%= slug %>" required>
        <option value="" selected disabled>Select Insurer</option>
        <option>Insurer 1</option><option>Insurer 2</option>
      </select>
    </div>
    <%- include('./amount-field', { slug: slug, href: href, showPlans: false, amountLabel: 'Premium Amount' }) %>
    <div class="d-grid mt-4">
      <a class="btn btn-primary" href="<%= href %>">Continue to Pay Bill</a>
    </div>
  </form>
</div>
