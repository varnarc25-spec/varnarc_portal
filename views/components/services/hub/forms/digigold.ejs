<% var slug = 'digigold'; var href = hubHrefForPanel(slug); var active = panelIsActive(slug); %>
<div class="hub-tab-panel<%= active ? ' is-active' : '' %>" data-hub-panel="<%= slug %>" id="hub-panel-<%= slug %>" role="tabpanel"<%= active ? '' : ' hidden' %>>
  <h2 class="text-6 mb-4">Digi Gold &amp; Silver</h2>
  <form class="hub-service-form" action="<%= href %>" method="get">
    <div class="mb-3">
      <label class="form-label" for="metal-digigold">Metal</label>
      <select class="form-select" id="metal-digigold" required>
        <option value="gold">Gold</option>
        <option value="silver">Silver</option>
      </select>
    </div>
    <div class="mb-3">
      <label class="form-label" for="amt-digigold">Amount (INR)</label>
      <input type="text" class="form-control" id="amt-digigold" placeholder="Enter amount" inputmode="decimal" required />
    </div>
    <div class="d-grid mt-4">
      <a class="btn btn-primary" href="<%= href %>">Continue</a>
    </div>
  </form>
</div>
