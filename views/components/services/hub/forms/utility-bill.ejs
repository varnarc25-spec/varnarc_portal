<%
  var slug = typeof panelSlug !== 'undefined' ? String(panelSlug) : 'electricity';
  var title = typeof panelTitle !== 'undefined' ? panelTitle : 'Pay your Electricity Bill';
  var showStateField = typeof includeState !== 'undefined' ? !!includeState : false;
  var href = hubHrefForPanel(slug);
  var active = panelIsActive(slug);
%>
<div class="hub-tab-panel<%= active ? ' is-active' : '' %>" data-hub-panel="<%= slug %>" id="hub-panel-<%= slug %>" role="tabpanel"<%= active ? '' : ' hidden' %>>
  <%- include('../panel-header', { panelTitle: title, panelSlug: slug, href: href }) %>
  <form class="hub-service-form" action="<%= href %>" method="get">
    <div class="mb-3">
      <label class="form-label" for="op-<%= slug %>">Your Operator</label>
      <select class="form-select" id="op-<%= slug %>" required>
        <option value="" selected disabled>Select Your Operator</option>
        <option>Operator 1</option><option>Operator 2</option><option>Operator 3</option>
      </select>
    </div>
    <% if (showStateField) { %>
    <div class="mb-3">
      <label class="form-label" for="state-<%= slug %>">Your State</label>
      <select class="form-select" id="state-<%= slug %>">
        <option value="" selected disabled>Select Your State</option>
        <option>Andhra Pradesh</option><option>Karnataka</option><option>Maharashtra</option><option>Tamil Nadu</option>
      </select>
    </div>
    <% } %>
    <div class="mb-3">
      <label class="form-label" for="svc-<%= slug %>">Consumer / Service Number</label>
      <input type="text" class="form-control" id="svc-<%= slug %>" placeholder="Enter number" required />
    </div>
    <%- include('./amount-field', { slug: slug, href: href, showPlans: false, amountLabel: 'Amount' }) %>
    <div class="d-grid mt-4">
      <a class="btn btn-primary" href="<%= href %>">Continue to Pay Bill</a>
    </div>
  </form>
</div>
