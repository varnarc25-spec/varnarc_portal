<% var slug = 'dth'; var href = hubHrefForPanel(slug); var active = panelIsActive(slug); %>
<div class="hub-tab-panel<%= active ? ' is-active' : '' %>" data-hub-panel="<%= slug %>" id="hub-panel-<%= slug %>" role="tabpanel"<%= active ? '' : ' hidden' %>>
  <h2 class="text-6 mb-4">DTH Recharge</h2>
  <form class="hub-service-form" action="<%= href %>" method="get">
    <div class="mb-3">
      <label class="form-label" for="op-dth">Your Operator</label>
      <select class="form-select" id="op-dth" required>
        <option value="" selected disabled>Select Your Operator</option>
        <option>Airtel</option><option>Jio</option><option>Tata Play</option><option>Dish TV</option>
      </select>
    </div>
    <div class="mb-3">
      <label class="form-label" for="card-dth">Your Card Number</label>
      <input type="text" class="form-control" id="card-dth" placeholder="Enter Card Number" required />
    </div>
    <%- include('./amount-field', { slug: slug, href: href, showPlans: true }) %>
    <div class="d-grid mt-4">
      <a class="btn btn-primary" href="<%= href %>">Continue to Recharge</a>
    </div>
  </form>
</div>
