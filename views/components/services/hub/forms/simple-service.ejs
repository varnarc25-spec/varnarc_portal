<%
  var slug = typeof panelSlug !== 'undefined' ? String(panelSlug) : 'generic';
  var title = typeof panelTitle !== 'undefined' ? panelTitle : 'Service';
  var cta = typeof ctaText !== 'undefined' ? ctaText : 'Continue';
  var href = hubHrefForPanel(slug);
  var active = panelIsActive(slug);
%>
<div class="hub-tab-panel<%= active ? ' is-active' : '' %>" data-hub-panel="<%= slug %>" id="hub-panel-<%= slug %>" role="tabpanel"<% if (!active) { %> hidden<% } %>>
  <%- include('../panel-header', { panelTitle: title, panelSlug: slug, href: href }) %>
  <form class="hub-service-form" action="<%= href %>" method="get">
    <p class="text-muted small mb-3">Complete your <%= title %> transaction securely on Varnarc.</p>
    <div class="mb-3">
      <label class="form-label" for="ref-<%= slug %>">Reference / Account</label>
      <input type="text" class="form-control" id="ref-<%= slug %>" placeholder="Enter details" required />
    </div>
    <%- include('./amount-field', { slug: slug, href: href, showPlans: false, amountLabel: 'Amount' }) %>
    <div class="d-grid mt-4">
      <a class="btn btn-primary" href="<%= href %>"><%= cta %></a>
    </div>
  </form>
</div>
