<% var slug = 'mobile'; var href = hubHrefForPanel(slug); var active = panelIsActive(slug); %>
<div class="hub-tab-panel<%= active ? ' is-active' : '' %>" data-hub-panel="<%= slug %>" id="hub-panel-<%= slug %>" role="tabpanel"<%= active ? '' : ' hidden' %>>
  <h2 class="text-6 mb-4">Mobile Recharge or Bill Payment</h2>
  <form class="hub-service-form" action="<%= href %>" method="get">
    <div class="mb-3">
      <div class="form-check form-check-inline">
        <input class="form-check-input" type="radio" name="plan-mobile" id="prepaid-mobile" value="prepaid" checked />
        <label class="form-check-label" for="prepaid-mobile">Prepaid</label>
      </div>
      <div class="form-check form-check-inline">
        <input class="form-check-input" type="radio" name="plan-mobile" id="postpaid-mobile" value="postpaid" />
        <label class="form-check-label" for="postpaid-mobile">Postpaid</label>
      </div>
    </div>
    <div class="mb-3">
      <label class="form-label" for="num-mobile">Mobile Number</label>
      <input type="tel" class="form-control" id="num-mobile" placeholder="Enter Mobile Number" maxlength="10" inputmode="numeric" required />
    </div>
    <div class="mb-3">
      <label class="form-label" for="op-mobile">Your Operator</label>
      <select class="form-select" id="op-mobile" required>
        <option value="" selected disabled>Select Your Operator</option>
        <option>Airtel</option><option>Jio</option><option>Vi</option><option>BSNL</option>
      </select>
    </div>
    <%- include('./amount-field', { slug: slug, href: href, showPlans: true }) %>
    <div class="d-grid mt-4">
      <a class="btn btn-primary" href="<%= href %>">Continue to Recharge</a>
    </div>
  </form>
</div>
