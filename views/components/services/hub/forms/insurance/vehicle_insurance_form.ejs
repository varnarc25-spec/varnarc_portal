<%
  var slug =
    typeof panelSlug !== "undefined" && panelSlug
      ? String(panelSlug)
      : "insurance-car";
  var panelTitle =
    typeof panelTitle !== "undefined" && panelTitle ? String(panelTitle) : "Car Insurance";
  var vehicleType =
    typeof vehicleType !== "undefined" && vehicleType ? String(vehicleType) : "car";
  var hubEmbed = typeof hubEmbed === "undefined" ? true : !!hubEmbed;
  var href =
    typeof hubHrefForPanel === "function"
      ? hubHrefForPanel(slug)
      : "/services/Insurance/index";
  var active =
    hubEmbed && typeof panelIsActive === "function" ? panelIsActive(slug) : true;
  var searchId = "motor-insurer-" + slug;
  var idvDefault = vehicleType === "bike" ? 300000 : 600000;
  var showroomPlaceholder = vehicleType === "bike" ? "250000" : "800000";
  var topInsurers = [
    { key: "hdfc ergo", initials: "HE", name: "HDFC ERGO", color: "c1" },
    { key: "icici lombard", initials: "IL", name: "ICICI Lombard", color: "c3" },
    { key: "bajaj allianz", initials: "BA", name: "Bajaj Allianz", color: "c2" },
    { key: "tata aig", initials: "TA", name: "Tata AIG", color: "c4" },
  ];
  var allInsurers = [
    { key: "hdfc ergo", initials: "HE", name: "HDFC ERGO", color: "c1" },
    { key: "icici lombard", initials: "IL", name: "ICICI Lombard", color: "c3" },
    { key: "bajaj allianz", initials: "BA", name: "Bajaj Allianz", color: "c2" },
    { key: "tata aig", initials: "TA", name: "Tata AIG", color: "c4" },
    { key: "reliance general", initials: "RG", name: "Reliance General", color: "c5" },
    { key: "sbi general", initials: "SG", name: "SBI General", color: "c0" },
    { key: "future generali", initials: "FG", name: "Future Generali", color: "c2" },
    { key: "royal sundaram", initials: "RS", name: "Royal Sundaram", color: "c6" },
  ];
%>
<% if (hubEmbed) { %>
<div
  class="hub-tab-panel service-insurance-hub-page electricity-hub-panel vehicle-insurance-hub-panel<%= active ? ' is-active' : '' %>"
  data-hub-panel="<%= slug %>"
  id="hub-panel-<%= slug %>"
  role="tabpanel"
  data-insurance-hub
  data-insurance-product="vehicle"
  data-vehicle-type="<%= vehicleType %>"
  <% if (!active) { %> hidden<% } %>
>
<% } else { %>
<div
  class="service-insurance-hub-page electricity-hub-panel vehicle-insurance-hub-panel is-active"
  data-insurance-hub
  data-insurance-product="vehicle"
  data-vehicle-type="<%= vehicleType %>"
>
<% } %>

  <%- include('../../panel-header', { panelTitle: panelTitle, panelSlug: slug, href: href }) %>

  <div class="ai-calculator-section mb-4">
    <div class="ai-calculator-bar" role="toolbar" aria-label="Insurance calculators">
      <button type="button" class="ai-calculator-btn" data-ai-calc-tab="premium">
        <i class="bi bi-calculator" aria-hidden="true"></i> Premium calculator
      </button>
      <button type="button" class="ai-calculator-btn" data-ai-calc-tab="cover">
        <i class="bi bi-shield-check" aria-hidden="true"></i> IDV calculator
      </button>
      <button type="button" class="ai-calculator-btn" data-ai-calc-tab="benefits">
        <i class="bi bi-list-check" aria-hidden="true"></i> Benefit checker
      </button>
    </div>

    <div class="ai-calculator-panel" data-ai-calc-panel="premium">
      <p class="ai-calculator-panel__title">Estimate motor premium</p>
      <div class="row g-2">
        <div class="col-sm-4">
          <label class="form-label small mb-1">IDV (₹)</label>
          <input type="number" class="form-control form-control-sm" data-ai-calc-idv min="50000" step="10000" value="<%= idvDefault %>" />
        </div>
        <div class="col-sm-4">
          <label class="form-label small mb-1">NCB %</label>
          <select class="form-select form-select-sm" data-ai-calc-ncb>
            <option value="0">0%</option>
            <option value="20">20%</option>
            <option value="35" selected>35%</option>
            <option value="50">50%</option>
          </select>
        </div>
        <div class="col-sm-4">
          <label class="form-label small mb-1">Vehicle</label>
          <input type="text" class="form-control form-control-sm" value="<%= panelTitle %>" readonly />
        </div>
      </div>
      <button type="button" class="btn btn-sm btn-primary mt-2" data-ai-calc-prem-run>Calculate premium</button>
      <p class="ai-calculator-result mb-0" data-ai-calc-prem-out>Indicative premium for <%= vehicleType === 'bike' ? 'two-wheeler' : 'car' %> insurance.</p>
    </div>

    <div class="ai-calculator-panel" data-ai-calc-panel="cover" hidden>
      <p class="ai-calculator-panel__title">Suggested IDV from ex-showroom price</p>
      <label class="form-label small mb-1">Ex-showroom price (₹)</label>
      <input type="number" class="form-control form-control-sm mb-2" data-ai-calc-ex-showroom min="50000" step="10000" placeholder="e.g. <%= showroomPlaceholder %>" />
      <button type="button" class="btn btn-sm btn-primary" data-ai-calc-cover-run>Calculate IDV</button>
      <p class="ai-calculator-result mb-0" data-ai-calc-cover-out>IDV is typically about 90% of ex-showroom for new vehicles.</p>
    </div>

    <div class="ai-calculator-panel" data-ai-calc-panel="benefits" hidden>
      <p class="ai-calculator-panel__title">What’s included in your plan?</p>
      <label class="form-label small mb-1" for="ai-benefit-<%= slug %>">Plan type</label>
      <select class="form-select form-select-sm mb-2" id="ai-benefit-<%= slug %>" data-ai-calc-benefit-plan>
        <option value="essential">Third Party</option>
        <option value="standard" selected>Comprehensive</option>
        <option value="zerodep">Zero Depreciation</option>
      </select>
      <div data-ai-calc-benefit-out></div>
    </div>
  </div>

  <div class="electricity-hub-pay-web mb-4" data-insurance-step="pick">
    <div class="ai-highlights">
      <div class="ai-highlight">
        <strong>Mandatory TP</strong>
        <span>Third-party cover is legally required — avoid fines and legal risk.</span>
      </div>
      <div class="ai-highlight">
        <strong>Own damage</strong>
        <span>Comprehensive plans protect your <%= vehicleType === 'bike' ? 'bike' : 'car' %> from accident, theft, and fire.</span>
      </div>
      <div class="ai-highlight">
        <strong>Instant policy</strong>
        <span>Digital policies with PDF delivery in minutes after payment.</span>
      </div>
    </div>
    <p class="service-recharge-value-prop mb-3">
      Renew or buy <%= panelTitle.toLowerCase() %> online. Use calculators above, compare insurers, and get an instant quote — cashless garages and 24/7 support on Varnarc.
    </p>
    <div class="electricity-hub-search-wrap">
      <input type="search" class="electricity-hub-search-input" id="<%= searchId %>" data-insurance-insurer-search placeholder="Search insurer" autocomplete="off" aria-label="Search insurer" />
      <button type="button" class="electricity-hub-search-clear" data-insurance-search-clear aria-label="Clear search" hidden>
        <i class="bi bi-x-lg" aria-hidden="true"></i>
      </button>
    </div>
    <section class="electricity-hub-providers-section" aria-labelledby="ins-top-<%= slug %>">
      <h3 id="ins-top-<%= slug %>" class="electricity-hub-section-title">Top insurers</h3>
      <ul class="electricity-hub-providers list-unstyled mb-0" data-insurance-insurer-list="top">
        <% topInsurers.forEach(function (p) { %>
        <li data-biller="<%= p.key %>">
          <button type="button" class="electricity-hub-provider-btn" data-insurance-insurer="<%= p.key %>">
            <span class="electricity-hub-provider-logo electricity-hub-provider-logo--<%= p.color %>" aria-hidden="true"><%= p.initials %></span>
            <span class="electricity-hub-provider-name"><%= p.name %></span>
          </button>
        </li>
        <% }) %>
      </ul>
    </section>
    <section class="electricity-hub-providers-section electricity-hub-providers-section--spaced" aria-labelledby="ins-all-<%= slug %>">
      <h3 id="ins-all-<%= slug %>" class="electricity-hub-section-title">All insurers</h3>
      <ul class="electricity-hub-providers list-unstyled mb-0" data-insurance-insurer-list="all">
        <% allInsurers.forEach(function (p) { %>
        <li data-biller="<%= p.key %>">
          <button type="button" class="electricity-hub-provider-btn" data-insurance-insurer="<%= p.key %>">
            <span class="electricity-hub-provider-logo electricity-hub-provider-logo--<%= p.color %>" aria-hidden="true"><%= p.initials %></span>
            <span class="electricity-hub-provider-name"><%= p.name %></span>
          </button>
        </li>
        <% }) %>
      </ul>
    </section>
  </div>

  <div data-insurance-step="quote" hidden>
    <button type="button" class="electricity-hub-back btn btn-link p-0 mb-3" data-insurance-back>
      <i class="bi bi-arrow-left me-1" aria-hidden="true"></i> Change insurer
    </button>
    <p class="electricity-hub-selected-provider mb-3">
      <span class="electricity-hub-selected-provider__label">Insurer</span>
      <span class="electricity-hub-selected-provider__name" data-insurance-selected-insurer>—</span>
    </p>
    <div class="service-recharge-hero text-start">
      <p class="service-recharge-value-prop mb-3 mb-lg-4">
        <%= vehicleType === 'bike' ? 'Two-wheeler' : 'Car' %> repairs can cost lakhs. Choose third-party for compliance or comprehensive for full peace of mind — including theft, calamities, and accidental damage.
      </p>
      <div class="service-recharge-panel">
        <div class="service-recharge-card">
          <h2 class="text-6 mb-2">Get your <%= panelTitle.toLowerCase() %> quote</h2>
          <p class="service-recharge-card__sub">
            Enter your registration number, pick a plan, and see your premium instantly. We only use your details for the quote and policy.
          </p>
          <ol class="recharge-flow-steps mb-4" aria-label="Quote progress">
            <li class="recharge-flow-steps__segment is-active"><span class="recharge-flow-steps__label">Pick plan</span></li>
            <li class="recharge-flow-steps__segment"><span class="recharge-flow-steps__label">Vehicle details</span></li>
            <li class="recharge-flow-steps__segment"><span class="recharge-flow-steps__label">Get quote</span></li>
          </ol>
          <p class="small fw-semibold text-secondary mb-2">Recommended plans</p>
          <div class="ai-plan-grid" data-ai-plan-grid>
            <button type="button" class="ai-plan-card" data-ai-plan-card="essential">
              <p class="ai-plan-card__name">Third Party</p>
              <p class="ai-plan-card__cover">Legal TP only</p>
              <p class="ai-plan-card__price">from ₹2,148/yr</p>
            </button>
            <button type="button" class="ai-plan-card" data-ai-plan-card="standard">
              <p class="ai-plan-card__name">Comprehensive</p>
              <p class="ai-plan-card__cover">Own damage + TP</p>
              <p class="ai-plan-card__price">from ₹8,499/yr</p>
            </button>
            <button type="button" class="ai-plan-card" data-ai-plan-card="zerodep">
              <p class="ai-plan-card__name">Zero Dep</p>
              <p class="ai-plan-card__cover">Zero depreciation</p>
              <p class="ai-plan-card__price">from ₹12,499/yr</p>
            </button>
          </div>
          <input type="hidden" name="planKey" value="standard" data-ai-plan-key />
          <form class="service-recharge-form" data-insurance-quote-form novalidate>
            <div class="row g-3 mb-3">
              <div class="col-md-6">
                <label class="form-label" for="ins-name-<%= slug %>">Full name</label>
                <input type="text" class="form-control" id="ins-name-<%= slug %>" data-insurance-name autocomplete="name" required />
              </div>
              <div class="col-md-3">
                <label class="form-label" for="ins-age-<%= slug %>">Age</label>
                <input type="number" class="form-control" id="ins-age-<%= slug %>" data-insurance-age min="18" max="70" required />
              </div>
              <div class="col-md-3">
                <label class="form-label" for="ins-city-<%= slug %>">City</label>
                <input type="text" class="form-control" id="ins-city-<%= slug %>" data-insurance-city placeholder="e.g. Mumbai" />
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label" for="ins-reg-<%= slug %>">Registration number</label>
              <input type="text" class="form-control text-uppercase" id="ins-reg-<%= slug %>" data-insurance-reg placeholder="e.g. KA01AB1234" maxlength="12" required />
            </div>
            <div class="mb-3">
              <label class="form-label">Policy type</label>
              <select class="form-select" data-insurance-policy-type>
                <option>Renew existing</option>
                <option selected>New policy</option>
              </select>
            </div>
            <div class="mb-3">
              <label class="form-label" for="ins-mobile-<%= slug %>">Mobile number</label>
              <input type="tel" class="form-control" id="ins-mobile-<%= slug %>" data-insurance-mobile inputmode="numeric" maxlength="10" autocomplete="tel" required />
              <span class="input-hint">10-digit mobile for quote and policy PDF.</span>
            </div>
            <div class="recharge-trust-compact" aria-label="Trust highlights">
              <span class="recharge-trust-chip"><i class="bi bi-shield-fill-check"></i> IRDAI partners</span>
              <span class="recharge-trust-chip"><i class="bi bi-wrench"></i> Cashless garages</span>
              <span class="recharge-trust-chip"><i class="bi bi-lock-fill"></i> Secure checkout</span>
              <span class="recharge-trust-chip"><i class="bi bi-headset"></i> Renewal reminders</span>
            </div>
            <button type="submit" class="btn btn-primary w-100 mt-2" data-insurance-get-quote disabled>Get instant quote</button>
            <p class="small text-muted text-center mt-2 mb-0">
              <a href="mailto:support@varnarc.com">support@varnarc.com</a> · <a href="tel:+919739723973">+91 973 972 3973</a>
            </p>
          </form>
        </div>
      </div>
    </div>
    <section class="service-recharge-info mt-4">
      <ul class="nav nav-tabs">
        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#pane-v-why-<%= slug %>">Why motor insurance</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#pane-v-claim-<%= slug %>">Claims</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#pane-v-varn-<%= slug %>">Why Varnarc</button></li>
      </ul>
      <div class="tab-content pt-4">
        <div class="tab-pane fade show active" id="pane-v-why-<%= slug %>">
          <p class="mb-0">
            Motor insurance covers third-party liability by law. Comprehensive adds protection for your own vehicle. Use the <strong>Premium</strong> and <strong>IDV</strong> calculators before you renew.
          </p>
        </div>
        <div class="tab-pane fade" id="pane-v-claim-<%= slug %>">
          <p class="mb-0">
            For claims, inform the insurer immediately, file an FIR if required, and use network garages for cashless repair. Email <a href="mailto:support@varnarc.com">support@varnarc.com</a> for assistance.
          </p>
        </div>
        <div class="tab-pane fade" id="pane-v-varn-<%= slug %>">
          <p class="mb-0">Compare quotes from multiple insurers, transparent plan cards, and renewal reminders — all on Varnarc.</p>
        </div>
      </div>
    </section>
  </div>
</div>
