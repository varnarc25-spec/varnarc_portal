<%
  var slug =
    typeof panelSlug !== "undefined" && panelSlug
      ? String(panelSlug)
      : "insurance-term";
  var hubEmbed = typeof hubEmbed === "undefined" ? true : !!hubEmbed;
  var href =
    typeof hubHrefForPanel === "function"
      ? hubHrefForPanel(slug)
      : "/services/Insurance/index";
  var active =
    hubEmbed && typeof panelIsActive === "function" ? panelIsActive(slug) : true;
  var searchId = "term-insurer-" + slug;
  var topInsurers = [
    { key: "lic of india", initials: "LI", name: "LIC of India", color: "c0" },
    { key: "hdfc life", initials: "HL", name: "HDFC Life", color: "c1" },
    { key: "icici prudential", initials: "IP", name: "ICICI Prudential Life", color: "c3" },
    { key: "max life", initials: "MX", name: "Max Life Insurance", color: "c6" },
  ];
  var allInsurers = [
    { key: "lic of india", initials: "LI", name: "LIC of India", color: "c0" },
    { key: "hdfc life", initials: "HL", name: "HDFC Life", color: "c1" },
    { key: "icici prudential", initials: "IP", name: "ICICI Prudential Life", color: "c3" },
    { key: "max life", initials: "MX", name: "Max Life Insurance", color: "c6" },
    { key: "sbi life", initials: "SB", name: "SBI Life Insurance", color: "c0" },
    { key: "tata aia", initials: "TA", name: "Tata AIA Life", color: "c4" },
    { key: "pnb metlife", initials: "PM", name: "PNB MetLife", color: "c5" },
    { key: "bajaj allianz life", initials: "BA", name: "Bajaj Allianz Life", color: "c2" },
  ];
%>
<% if (hubEmbed) { %>
<div
  class="hub-tab-panel service-insurance-hub-page electricity-hub-panel term-insurance-hub-panel<%= active ? ' is-active' : '' %>"
  data-hub-panel="<%= slug %>"
  id="hub-panel-<%= slug %>"
  role="tabpanel"
  data-insurance-hub
  data-insurance-product="term"
  <% if (!active) { %> hidden<% } %>
>
<% } else { %>
<div class="service-insurance-hub-page electricity-hub-panel term-insurance-hub-panel is-active" data-insurance-hub data-insurance-product="term">
<% } %>

  <%- include('../../panel-header', { panelTitle: 'Term Life Insurance', panelSlug: slug, href: href }) %>

  <div class="ai-calculator-section mb-4">
    <div class="ai-calculator-bar" role="toolbar" aria-label="Insurance calculators">
      <button type="button" class="ai-calculator-btn" data-ai-calc-tab="premium">
        <i class="bi bi-calculator" aria-hidden="true"></i> Premium calculator
      </button>
      <button type="button" class="ai-calculator-btn" data-ai-calc-tab="cover">
        <i class="bi bi-shield-check" aria-hidden="true"></i> Cover calculator
      </button>
      <button type="button" class="ai-calculator-btn" data-ai-calc-tab="benefits">
        <i class="bi bi-list-check" aria-hidden="true"></i> Benefit checker
      </button>
    </div>

    <div class="ai-calculator-panel" data-ai-calc-panel="premium">
      <p class="ai-calculator-panel__title">Estimate term life premium</p>
      <div class="row g-2">
        <div class="col-sm-3"><label class="form-label small mb-1">Age</label><input type="number" class="form-control form-control-sm" data-ai-calc-prem-age min="18" max="65" value="32" /></div>
        <div class="col-sm-3"><label class="form-label small mb-1">Smoker?</label><div class="form-check mt-1"><input class="form-check-input" type="checkbox" data-ai-calc-smoker id="term-smoke-<%= slug %>" /><label class="form-check-label small" for="term-smoke-<%= slug %>">Yes</label></div></div>
        <div class="col-sm-6"><label class="form-label small mb-1">Life cover</label><select class="form-select form-select-sm" data-ai-calc-prem-cover><option value="5000000">₹50 lakh</option><option value="10000000" selected>₹1 Cr</option><option value="20000000">₹2 Cr</option></select></div>
      </div>
      <button type="button" class="btn btn-sm btn-primary mt-2" data-ai-calc-prem-run>Calculate premium</button>
      <p class="ai-calculator-result mb-0" data-ai-calc-prem-out>Indicative annual premium for term life plans.</p>
    </div>

    <div class="ai-calculator-panel" data-ai-calc-panel="cover" hidden>
      <p class="ai-calculator-panel__title">How much life cover do you need? (HLV)</p>
      <label class="form-label small mb-1">Monthly income (₹)</label>
      <input type="number" class="form-control form-control-sm mb-2" data-ai-calc-cover-income min="10000" step="1000" placeholder="e.g. 60000" />
      <label class="form-label small mb-1 mt-2">Existing life cover (₹)</label>
      <input type="number" class="form-control form-control-sm mb-2" data-ai-calc-existing-cover min="0" step="100000" value="0" />
      <button type="button" class="btn btn-sm btn-primary" data-ai-calc-cover-run>Suggest life cover</button>
      <p class="ai-calculator-result mb-0" data-ai-calc-cover-out>Rule of thumb: 15× annual income minus existing cover — adequate cover protects savings.</p>
    </div>
    <div class="ai-calculator-panel" data-ai-calc-panel="benefits" hidden>
      <p class="ai-calculator-panel__title">What’s included in your plan?</p>
      <label class="form-label small mb-1" for="ai-benefit-<%= slug %>">Plan type</label>
      <select class="form-select form-select-sm mb-2" id="ai-benefit-<%= slug %>" data-ai-calc-benefit-plan>
        <option value="essential">Smart Term</option>
        <option value="standard" selected>Income Shield</option>
        <option value="comprehensive">Max Protection</option>
      </select>
      <div data-ai-calc-benefit-out></div>
    </div>
  </div>

  <div class="electricity-hub-pay-web mb-4" data-insurance-step="pick">
    <div class="ai-highlights">
      <div class="ai-highlight"><strong>High cover, low cost</strong><span>Term plans offer large life cover at a fraction of traditional plans.</span></div>
      <div class="ai-highlight"><strong>Income replacement</strong><span>Protect your family’s lifestyle if something happens to you.</span></div>
      <div class="ai-highlight"><strong>Tax benefits</strong><span>Premiums may qualify under Section 80C (as per prevailing rules).</span></div>
    </div>
    <p class="service-recharge-value-prop mb-3">Compare term life plans from trusted insurers. Use calculators to estimate premium and sum insured, then get a personalised quote in minutes.</p>
    <div class="electricity-hub-search-wrap">
      <input type="search" class="electricity-hub-search-input" id="<%= searchId %>" data-insurance-insurer-search placeholder="Search insurer" autocomplete="off" aria-label="Search insurer" />
      <button type="button" class="electricity-hub-search-clear" data-insurance-search-clear aria-label="Clear search" hidden><i class="bi bi-x-lg" aria-hidden="true"></i></button>
    </div>
    <section class="electricity-hub-providers-section" aria-labelledby="ins-top-<%= slug %>">
      <h3 id="ins-top-<%= slug %>" class="electricity-hub-section-title">Top insurers</h3>
      <ul class="electricity-hub-providers list-unstyled mb-0" data-insurance-insurer-list="top">
        <% topInsurers.forEach(function (p) { %>
        <li data-biller="<%= p.key %>">
          <button type="button" class="electricity-hub-provider-btn" data-insurance-insurer="<%= p.key %>">
            <span class="electricity-hub-provider-logo electricity-hub-provider-logo--<%= p.color %>" aria-hidden="true"><%= p.initials %></span>
            <span class="electricity-hub-provider-name"><%= p.name %></span>
          </button>
        </li>
        <% }) %>
      </ul>
    </section>
    <section class="electricity-hub-providers-section electricity-hub-providers-section--spaced" aria-labelledby="ins-all-<%= slug %>">
      <h3 id="ins-all-<%= slug %>" class="electricity-hub-section-title">All insurers</h3>
      <ul class="electricity-hub-providers list-unstyled mb-0" data-insurance-insurer-list="all">
        <% allInsurers.forEach(function (p) { %>
        <li data-biller="<%= p.key %>">
          <button type="button" class="electricity-hub-provider-btn" data-insurance-insurer="<%= p.key %>">
            <span class="electricity-hub-provider-logo electricity-hub-provider-logo--<%= p.color %>" aria-hidden="true"><%= p.initials %></span>
            <span class="electricity-hub-provider-name"><%= p.name %></span>
          </button>
        </li>
        <% }) %>
      </ul>
    </section>
  </div>

  <div data-insurance-step="quote" hidden>
    <button type="button" class="electricity-hub-back btn btn-link p-0 mb-3" data-insurance-back>
      <i class="bi bi-arrow-left me-1" aria-hidden="true"></i> Change insurer
    </button>
    <p class="electricity-hub-selected-provider mb-3">
      <span class="electricity-hub-selected-provider__label">Insurer</span>
      <span class="electricity-hub-selected-provider__name" data-insurance-selected-insurer>—</span>
    </p>
    <div class="service-recharge-hero text-start">
      <p class="service-recharge-value-prop mb-3 mb-lg-4">If you are the primary earner, term life replaces your income for years years of savings in one hospital stay. Pick a plan that covers hospitalisation, daycare, and renewals — built for Indian families.</p>
      <div class="service-recharge-panel">
        <div class="service-recharge-card">
          <h2 class="text-6 mb-2">Get your term life quote</h2>
          <p class="service-recharge-card__sub">Choose cover amount, enter age and lifestyle details, and receive an indicative premium. No spam — details used only for your quote.</p>
          <ol class="recharge-flow-steps mb-4" aria-label="Quote progress">
            <li class="recharge-flow-steps__segment is-active"><span class="recharge-flow-steps__label">Pick plan</span></li>
            <li class="recharge-flow-steps__segment"><span class="recharge-flow-steps__label">Your details</span></li>
            <li class="recharge-flow-steps__segment"><span class="recharge-flow-steps__label">Get quote</span></li>
          </ol>
          <p class="small fw-semibold text-secondary mb-2">Recommended plans</p>
          <div class="ai-plan-grid" data-ai-plan-grid>
            <button type="button" class="ai-plan-card" data-ai-plan-card="essential"><p class="ai-plan-card__name">Smart Term</p><p class="ai-plan-card__cover">₹50L life cover</p><p class="ai-plan-card__price">from ₹5,999/yr</p></button>
            <button type="button" class="ai-plan-card" data-ai-plan-card="standard"><p class="ai-plan-card__name">Income Shield</p><p class="ai-plan-card__cover">₹1 Cr cover</p><p class="ai-plan-card__price">from ₹9,999/yr</p></button>
            <button type="button" class="ai-plan-card" data-ai-plan-card="comprehensive"><p class="ai-plan-card__name">Max Protection</p><p class="ai-plan-card__cover">₹2 Cr + riders</p><p class="ai-plan-card__price">from ₹18,999/yr</p></button>
          </div>
          <input type="hidden" name="planKey" value="standard" data-ai-plan-key />
          <form class="service-recharge-form" data-insurance-quote-form novalidate>
            <div class="row g-3 mb-3">
              <div class="col-md-6">
                <label class="form-label" for="ins-name-<%= slug %>">Full name</label>
                <input type="text" class="form-control" id="ins-name-<%= slug %>" data-insurance-name autocomplete="name" required />
              </div>
              <div class="col-md-3">
                <label class="form-label" for="ins-age-<%= slug %>">Age</label>
                <input type="number" class="form-control" id="ins-age-<%= slug %>" data-insurance-age min="18" max="65" required />
              </div>
              <div class="col-md-3">
                <label class="form-label" for="ins-city-<%= slug %>">City</label>
                <input type="text" class="form-control" id="ins-city-<%= slug %>" data-insurance-city placeholder="e.g. Bengaluru" />
              </div>
            </div>
            <div class="mb-3"><label class="form-label">Annual income (₹)</label><input type="number" class="form-control" data-insurance-income placeholder="e.g. 1200000" /></div>
            <div class="mb-3">
              <label class="form-label" for="ins-mobile-<%= slug %>">Mobile number</label>
              <input type="tel" class="form-control" id="ins-mobile-<%= slug %>" data-insurance-mobile inputmode="numeric" maxlength="10" autocomplete="tel" required />
              <span class="input-hint">10-digit mobile for quote and policy documents.</span>
            </div>
            <div class="recharge-trust-compact" aria-label="Trust highlights">
              <span class="recharge-trust-chip"><i class="bi bi-shield-fill-check"></i> IRDAI-regulated partners</span>
              <span class="recharge-trust-chip"><i class="bi bi-hospital"></i> Claims settlement</span>
              <span class="recharge-trust-chip"><i class="bi bi-lock-fill"></i> Secure data</span>
              <span class="recharge-trust-chip"><i class="bi bi-headset"></i> Claims help</span>
            </div>
            <button type="submit" class="btn btn-primary w-100 mt-2" data-insurance-get-quote disabled>Get instant quote</button>
            <p class="small text-muted text-center mt-2 mb-0">
              <a href="mailto:support@varnarc.com">support@varnarc.com</a> · <a href="tel:+919739723973">+91 973 972 3973</a>
            </p>
          </form>
        </div>
      </div>
    </div>
    <section class="service-recharge-info mt-4">
      <ul class="nav nav-tabs"><li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#pane-t-why-<%= slug %>">Why term life</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#pane-t-claim-<%= slug %>">Claims</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#pane-t-v-<%= slug %>">Why Varnarc</button></li></ul>
      <div class="tab-content pt-4">
        <div class="tab-pane fade show active" id="pane-t-why-<%= slug %>"><p class="mb-0">Term life pays your nominees a lump sum for hospital bills so you focus on recovery, not expenses. Use our <strong>Premium</strong> and <strong>Cover</strong> calculators before you buy.</p></div>
        <div class="tab-pane fade" id="pane-t-claim-<%= slug %>"><p class="mb-0">For cashless treatment, use a network hospital and show your health card. For reimbursement, submit bills within the insurer timeline. Email <a href="mailto:support@varnarc.com">support@varnarc.com</a> for help.</p></div>
        <div class="tab-pane fade" id="pane-t-v-<%= slug %>"><p class="mb-0">Compare insurers, transparent plan cards, and expert support — all in one place on Varnarc.</p></div>
      </div>
    </section>
  </div>
</div>
