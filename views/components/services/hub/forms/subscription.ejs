<% var slug = 'subscription'; var href = hubHrefForPanel(slug); var active = panelIsActive(slug); %>
<div class="hub-tab-panel<%= active ? ' is-active' : '' %>" data-hub-panel="<%= slug %>" id="hub-panel-<%= slug %>" role="tabpanel"<%= active ? '' : ' hidden' %>>
  <h2 class="text-6 mb-4">Subscription Recharge</h2>
  <form class="hub-service-form" action="<%= href %>" method="get">
    <div class="mb-3">
      <label class="form-label" for="op-subscription">Platform</label>
      <select class="form-select" id="op-subscription" required>
        <option value="" selected disabled>Select Platform</option>
        <option>Netflix</option><option>Amazon Prime</option><option>Disney+ Hotstar</option>
      </select>
    </div>
    <div class="mb-3">
      <label class="form-label" for="acct-subscription">Account / Registered Email</label>
      <input type="text" class="form-control" id="acct-subscription" placeholder="Enter account details" required />
    </div>
    <%- include('./amount-field', { slug: slug, href: href, showPlans: true }) %>
    <div class="d-grid mt-4">
      <a class="btn btn-primary" href="<%= href %>">Continue to Recharge</a>
    </div>
  </form>
</div>
