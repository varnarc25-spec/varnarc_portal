<% var slug = 'mobile-postpaid'; var href = hubHrefForPanel(slug); var active = panelIsActive(slug); %>
<div class="hub-tab-panel<%= active ? ' is-active' : '' %>" data-hub-panel="<%= slug %>" id="hub-panel-<%= slug %>" role="tabpanel"<%= active ? '' : ' hidden' %>>
  <h2 class="text-6 mb-4">Mobile Postpaid Bill Payment</h2>
  <form class="hub-service-form" action="<%= href %>" method="get">
    <div class="mb-3">
      <label class="form-label" for="num-postpaid">Mobile Number</label>
      <input type="tel" class="form-control" id="num-postpaid" placeholder="Enter Mobile Number" maxlength="10" inputmode="numeric" required />
    </div>
    <div class="mb-3">
      <label class="form-label" for="op-postpaid">Your Operator</label>
      <select class="form-select" id="op-postpaid" required>
        <option value="" selected disabled>Select Your Operator</option>
        <option>Airtel</option><option>Jio</option><option>Vi</option>
      </select>
    </div>
    <%- include('./amount-field', { slug: slug, href: href, showPlans: false, amountLabel: 'Bill Amount' }) %>
    <div class="d-grid mt-4">
      <a class="btn btn-primary" href="<%= href %>">Continue to Pay Bill</a>
    </div>
  </form>
</div>
