<section class="refer-earn-card-section" aria-labelledby="refer-earn-heading">
  <div class="container refer-earn-card-section__inner">
    <article class="refer-earn-card">
      <header class="refer-earn-card__header">
        <h2 id="refer-earn-heading" class="refer-earn-card__title">Refer &amp; Earn</h2>
        <p class="refer-earn-card__subtitle">Refer your friends and earn up to ₹20.</p>
      </header>

      <div class="row justify-content-center g-4">
        <div class="col-md-4">
          <div class="refer-earn-card__step">
            <div class="refer-earn-card__step-icon-wrap" aria-hidden="true">
              <i class="bi bi-megaphone-fill"></i>
            </div>
            <h3 class="refer-earn-card__step-title">You Refer Friends</h3>
            <p class="refer-earn-card__step-text">Share your referral link with friends. They get ₹10.</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="refer-earn-card__step">
            <div class="refer-earn-card__step-icon-wrap" aria-hidden="true">
              <i class="bi bi-box-arrow-in-right"></i>
            </div>
            <h3 class="refer-earn-card__step-title">Your Friends Register</h3>
            <p class="refer-earn-card__step-text">Your friends register using your referral link.</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="refer-earn-card__step">
            <div class="refer-earn-card__step-icon-wrap" aria-hidden="true">
              <i class="bi bi-currency-rupee"></i>
            </div>
            <h3 class="refer-earn-card__step-title">Earn You</h3>
            <p class="refer-earn-card__step-text">You get ₹20. You can use these credits to take recharge.</p>
          </div>
        </div>
      </div>

      <div class="refer-earn-card__cta">
        <a href="#!" class="btn btn-refer-earn">Get Started Earn</a>
      </div>
    </article>
  </div>
</section>
