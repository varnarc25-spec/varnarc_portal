<% var pageTitle = 'Subscription'; %>
<% var pageDescription = 'Pay OTT and subscription bills on Varnarc — select your provider and renew securely.'; %>
<% 
  var _play = typeof playStoreHref !== 'undefined' && playStoreHref ? playStoreHref : '';
  var _ios = typeof appStoreHref !== 'undefined' && appStoreHref ? appStoreHref : '';
  var downloadHref = _play || _ios || '#';
%>
<!DOCTYPE html>
<html lang="en">

<%- include('../../../components/landing/head') %>
<link rel="stylesheet" href="/assets/css/loan-repayment-page.css" />

<body class="landing-page service-item-page">
  <div class="landing-page1">
    <div class="sticky-header"><%- include('../../../components/landing/header') %></div>
  </div>

  <section class="section-space service-item-section loanrep-service-section">
    <div class="container text-start py-4">
      <div class="loanrep-section-inner" id="subSectionInner">
        <div class="loanrep-promo-wrap">
          <div class="loanrep-promo-scroll" tabindex="0" role="region" aria-label="Offers and shortcuts">
            <article class="loanrep-promo-card loanrep-promo-card--accent">
              <p class="loanrep-promo-card__title">Insta EMI Card — split spends into easy instalments</p>
              <a href="/services/FinancialHub/index" class="loanrep-promo-card__btn">Apply now</a>
            </article>
            <article class="loanrep-promo-card loanrep-promo-card--muted">
              <p class="loanrep-promo-card__title">Personal loan offers — check eligibility in minutes</p>
              <a href="/services/FinancialHub/index" class="loanrep-promo-card__btn">Explore now</a>
            </article>
            <article class="loanrep-promo-card loanrep-promo-card--muted">
              <p class="loanrep-promo-card__title">Flat 10% cashback on bill payments — eligible categories</p>
              <a href="/services/BillPayments/index" class="loanrep-promo-card__btn">Pay bills</a>
            </article>
            <article class="loanrep-promo-card loanrep-promo-card--muted">
              <p class="loanrep-promo-card__title">DTH &amp; mobile recharge — rewards on select packs</p>
              <a href="/services/Recharge/dth" class="loanrep-promo-card__btn">Recharge</a>
            </article>
          </div>
        </div>

        <div class="loanrep-pay-web">
          <label class="loanrep-pay-web__title" for="subProviderSearch">Pay on Web</label>
          <input type="search" id="subProviderSearch" class="loanrep-search-input" placeholder="Search your provider" autocomplete="off" aria-label="Search your subscription provider" />
        </div>

        <section class="loanrep-providers-block" aria-labelledby="sub-top-heading">
          <h2 id="sub-top-heading" class="loanrep-section-title">Top service providers</h2>
          <ul class="loanrep-providers list-unstyled mb-0 loanrep-filter-list" id="subTopList">
            <li data-provider="amazon prime"><span class="loanrep-biller-logo loanrep-biller-logo--c4" aria-hidden="true">AP</span><span class="fw-semibold">Amazon Prime</span></li>
            <li data-provider="jiohotstar"><span class="loanrep-biller-logo loanrep-biller-logo--c2" aria-hidden="true">JH</span><span class="fw-semibold">JioHotstar</span></li>
            <li data-provider="pocket fm"><span class="loanrep-biller-logo loanrep-biller-logo--c5" aria-hidden="true">PF</span><span class="fw-semibold">Pocket FM</span></li>
            <li data-provider="sonyliv"><span class="loanrep-biller-logo loanrep-biller-logo--c3" aria-hidden="true">SL</span><span class="fw-semibold">SonyLIV</span></li>
            <li data-provider="zee entertainment"><span class="loanrep-biller-logo loanrep-biller-logo--c6" aria-hidden="true">ZE</span><span class="fw-semibold">Zee Entertainment Enterprises Limited</span></li>
          </ul>
        </section>

        <section class="loanrep-providers-block" aria-labelledby="sub-all-heading">
          <h2 id="sub-all-heading" class="loanrep-section-title">All service providers</h2>
          <ul class="loanrep-providers list-unstyled mb-0 loanrep-filter-list" id="subAllList">
            <li data-provider="apollo 24 7"><span class="loanrep-biller-logo loanrep-biller-logo--c0" aria-hidden="true">A7</span><span class="fw-semibold">APOLLO 24|7</span></li>
            <li data-provider="acemoney"><span class="loanrep-biller-logo loanrep-biller-logo--c1" aria-hidden="true">AC</span><span class="fw-semibold">Acemoney</span></li>
            <li data-provider="airtel xstream"><span class="loanrep-biller-logo loanrep-biller-logo--c7" aria-hidden="true">AX</span><span class="fw-semibold">Airtel Xstream</span></li>
            <li data-provider="akshar vishwa"><span class="loanrep-biller-logo loanrep-biller-logo--c2" aria-hidden="true">AV</span><span class="fw-semibold">Akshar Vishwa</span></li>
            <li data-provider="amazon prime"><span class="loanrep-biller-logo loanrep-biller-logo--c4" aria-hidden="true">AP</span><span class="fw-semibold">Amazon Prime</span></li>
            <li data-provider="discovery plus"><span class="loanrep-biller-logo loanrep-biller-logo--c5" aria-hidden="true">D+</span><span class="fw-semibold">Discovery Plus</span></li>
            <li data-provider="eros now"><span class="loanrep-biller-logo loanrep-biller-logo--c6" aria-hidden="true">EN</span><span class="fw-semibold">Eros Now</span></li>
            <li data-provider="jiohotstar"><span class="loanrep-biller-logo loanrep-biller-logo--c2" aria-hidden="true">JH</span><span class="fw-semibold">JioHotstar</span></li>
            <li data-provider="lionsgate play"><span class="loanrep-biller-logo loanrep-biller-logo--c3" aria-hidden="true">LG</span><span class="fw-semibold">Lionsgate Play</span></li>
            <li data-provider="manorama max"><span class="loanrep-biller-logo loanrep-biller-logo--c0" aria-hidden="true">MM</span><span class="fw-semibold">ManoramaMAX</span></li>
            <li data-provider="netflix"><span class="loanrep-biller-logo loanrep-biller-logo--c1" aria-hidden="true">NF</span><span class="fw-semibold">Netflix</span></li>
            <li data-provider="pocket fm"><span class="loanrep-biller-logo loanrep-biller-logo--c5" aria-hidden="true">PF</span><span class="fw-semibold">Pocket FM</span></li>
            <li data-provider="sonyliv"><span class="loanrep-biller-logo loanrep-biller-logo--c3" aria-hidden="true">SL</span><span class="fw-semibold">SonyLIV</span></li>
            <li data-provider="spotify india"><span class="loanrep-biller-logo loanrep-biller-logo--c7" aria-hidden="true">SP</span><span class="fw-semibold">Spotify India</span></li>
            <li data-provider="sun nxt"><span class="loanrep-biller-logo loanrep-biller-logo--c4" aria-hidden="true">SN</span><span class="fw-semibold">Sun NXT</span></li>
            <li data-provider="voot select"><span class="loanrep-biller-logo loanrep-biller-logo--c6" aria-hidden="true">VS</span><span class="fw-semibold">Voot Select</span></li>
            <li data-provider="youtube premium"><span class="loanrep-biller-logo loanrep-biller-logo--c0" aria-hidden="true">YT</span><span class="fw-semibold">YouTube Premium</span></li>
            <li data-provider="zee entertainment"><span class="loanrep-biller-logo loanrep-biller-logo--c6" aria-hidden="true">ZE</span><span class="fw-semibold">Zee Entertainment Enterprises Limited</span></li>
          </ul>
        </section>

        <div id="subBillPanel" class="loanrep-bill-panel" aria-hidden="true">
          <div class="loanrep-bill-panel__head loanrep-bill-panel__head--sub">
            <div class="loanrep-bill-panel__brand">
              <span class="loanrep-bill-panel__logo-mini" id="subPanelLogo" aria-hidden="true"></span>
              <span class="loanrep-bill-panel__brand-name" id="subSelectedName"></span>
            </div>
            <button type="button" class="loanrep-change-provider loanrep-change-provider--accent" id="subChangeProvider">Change</button>
          </div>
          <div class="loanrep-loan-field">
            <label class="loanrep-loan-label" for="subMobile">Mobile Number</label>
            <input type="tel" id="subMobile" class="loanrep-loan-input" maxlength="10" inputmode="numeric" pattern="[0-9]*" autocomplete="tel" aria-describedby="subMobileHint" />
            <p id="subMobileHint" class="loanrep-loan-hint">Please enter 10 digit Mobile Number</p>
          </div>
          <div class="loanrep-loan-field">
            <label class="loanrep-loan-label" for="subPlan">Plan</label>
            <select id="subPlan" class="loanrep-loan-input loanrep-loan-input--secondary" aria-describedby="subPlanHint">
              <option value="" selected disabled>Select plan</option>
              <option value="monthly">Monthly</option>
              <option value="quarterly">Quarterly</option>
              <option value="half_yearly">Half-yearly</option>
              <option value="annual">Annual</option>
              <option value="family_premium">Family / Premium</option>
            </select>
            <p id="subPlanHint" class="loanrep-loan-hint">Please select Plan</p>
          </div>
          <div class="loanrep-consent">
            <input type="checkbox" id="subConsent" />
            <label for="subConsent">I hereby authorize <strong id="subConsentProviderName"></strong> and Varnarc to access future bills and to facilitate the provision of bill reminders.</label>
          </div>
          <div class="loanrep-fetch-wrap">
            <button type="button" class="loanrep-fetch-btn" id="subFetchBill" disabled>Fetch your bill</button>
          </div>
          <p class="loanrep-fetch-status" id="subFetchStatus" role="status" aria-live="polite"></p>
        </div>

        <section class="loanrep-app-strip" aria-labelledby="sub-app-heading">
          <div>
            <h2 id="sub-app-heading" class="loanrep-app-strip__title">Continue on the app</h2>
            <p class="loanrep-app-strip__sub">Download the app to redeem your rewards</p>
            <% if (_play && _ios) { %>
            <p class="small text-muted mb-0 mt-2">
              <a href="<%= _ios %>" class="link-secondary" rel="noopener noreferrer" target="_blank">App Store</a>
              <span class="text-muted px-1">|</span>
              <a href="<%= _play %>" class="link-secondary" rel="noopener noreferrer" target="_blank">Google Play</a>
            </p>
            <% } %>
          </div>
          <a class="loanrep-download-btn" href="<%= downloadHref %>"<% if (downloadHref !== '#') { %> rel="noopener noreferrer" target="_blank"<% } %> aria-label="Download the Varnarc app">Download</a>
        </section>

        <section class="loanrep-faq" aria-labelledby="sub-faq-heading">
          <h2 id="sub-faq-heading">Frequently asked questions</h2>
          <div class="accordion" id="subFaq">
            <div class="accordion-item">
              <h3 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#subFaq1" aria-expanded="false" aria-controls="subFaq1">
                  How will my subscription get activated?
                </button>
              </h3>
              <div id="subFaq1" class="accordion-collapse collapse" data-bs-parent="#subFaq">
                <div class="accordion-body">
                  After payment succeeds, the provider usually activates your plan within a few minutes. Use the same mobile number registered with the service. If activation is delayed, check your SMS or email from the provider or contact their support with your transaction ID from Varnarc.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <h3 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#subFaq2" aria-expanded="false" aria-controls="subFaq2">
                  Can I renew a subscription for someone else?
                </button>
              </h3>
              <div id="subFaq2" class="accordion-collapse collapse" data-bs-parent="#subFaq">
                <div class="accordion-body">
                  Enter the mobile number linked to the subscription account you are paying for. Some providers only allow renewal for the registered number — if fetch fails, verify the number on the provider&apos;s app or website.
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="loanrep-query">
          <p>Still have a query?</p>
          <a class="loanrep-query-card" href="mailto:support@varnarc.com?subject=Subscription%20recharge%20support">
            <i class="bi bi-question-circle-fill" aria-hidden="true"></i>
            Raise a request
          </a>
        </section>
      </div>
    </div>
  </section>

<%- include('../../../components/landing/footer') %>
<%- include('../../../components/landing/scripts') %>
<script>
(function () {
  var input = document.getElementById("subProviderSearch");
  var lists = document.querySelectorAll("#subSectionInner .loanrep-filter-list");
  var sectionInner = document.getElementById("subSectionInner");
  var panel = document.getElementById("subBillPanel");
  var panelLogo = document.getElementById("subPanelLogo");
  var selectedNameEl = document.getElementById("subSelectedName");
  var consentNameEl = document.getElementById("subConsentProviderName");
  var mobileInput = document.getElementById("subMobile");
  var planSelect = document.getElementById("subPlan");
  var consentCb = document.getElementById("subConsent");
  var fetchBtn = document.getElementById("subFetchBill");
  var fetchStatus = document.getElementById("subFetchStatus");
  var changeBtn = document.getElementById("subChangeProvider");
  var selectedLi = null;

  function allProviderLis() {
    return document.querySelectorAll("#subTopList li, #subAllList li");
  }

  function isLiVisible(li) {
    return li && li.style.display !== "none";
  }

  function getDisplayName(li) {
    var span = li.querySelector(".fw-semibold");
    return span ? span.textContent.trim() : String(li.textContent || "").trim();
  }

  function isValidMobile(v) {
    return /^[0-9]{10}$/.test(String(v || ""));
  }

  function hasPlan() {
    return planSelect && String(planSelect.value || "").length > 0;
  }

  function syncFetchState() {
    if (!fetchBtn || !mobileInput || !planSelect || !consentCb) return;
    fetchBtn.disabled =
      !isValidMobile(mobileInput.value) || !hasPlan() || !consentCb.checked;
  }

  function clearSelection() {
    if (selectedLi) selectedLi.classList.remove("is-selected");
    selectedLi = null;
    if (panel) {
      panel.classList.remove("is-visible");
      panel.setAttribute("aria-hidden", "true");
    }
    if (panelLogo) panelLogo.textContent = "";
    if (mobileInput) {
      mobileInput.value = "";
      mobileInput.classList.remove("loanrep-loan-input--invalid");
    }
    if (planSelect) {
      planSelect.selectedIndex = 0;
      planSelect.classList.remove("loanrep-loan-input--invalid");
    }
    if (consentCb) consentCb.checked = false;
    if (fetchStatus) fetchStatus.textContent = "";
    syncFetchState();
  }

  function showPanelFor(li) {
    if (!panel || !li) return;
    if (selectedLi) selectedLi.classList.remove("is-selected");
    selectedLi = li;
    selectedLi.classList.add("is-selected");
    var name = getDisplayName(li);
    if (selectedNameEl) selectedNameEl.textContent = name;
    if (consentNameEl) consentNameEl.textContent = name;
    var logoEl = li.querySelector(".loanrep-biller-logo");
    if (panelLogo && logoEl) panelLogo.textContent = String(logoEl.textContent || "").trim();
    if (mobileInput) {
      mobileInput.value = "";
      mobileInput.classList.remove("loanrep-loan-input--invalid");
    }
    if (planSelect) {
      planSelect.selectedIndex = 0;
      planSelect.classList.remove("loanrep-loan-input--invalid");
    }
    if (consentCb) consentCb.checked = false;
    if (fetchStatus) fetchStatus.textContent = "";
    panel.classList.add("is-visible");
    panel.setAttribute("aria-hidden", "false");
    syncFetchState();
    try {
      li.scrollIntoView({ behavior: "smooth", block: "nearest" });
    } catch (e) {
      li.scrollIntoView(false);
    }
    window.setTimeout(function () {
      if (mobileInput) mobileInput.focus();
    }, 150);
  }

  function initListA11y() {
    var lis = allProviderLis();
    for (var j = 0; j < lis.length; j++) {
      lis[j].setAttribute("tabindex", "0");
      lis[j].setAttribute("role", "button");
    }
  }

  if (input && lists.length) {
    input.addEventListener("input", function () {
      var q = String(input.value || "").trim().toLowerCase();
      for (var L = 0; L < lists.length; L++) {
        var items = lists[L].querySelectorAll("li");
        for (var i = 0; i < items.length; i++) {
          var li = items[i];
          var key = (li.getAttribute("data-provider") || li.textContent || "").toLowerCase();
          li.style.display = !q || key.indexOf(q) !== -1 ? "" : "none";
        }
      }
      if (selectedLi && !isLiVisible(selectedLi)) clearSelection();
    });
  }

  if (sectionInner) {
    sectionInner.addEventListener("click", function (e) {
      var li = e.target && e.target.closest ? e.target.closest("#subTopList li, #subAllList li") : null;
      if (!li || !isLiVisible(li)) return;
      showPanelFor(li);
    });
    sectionInner.addEventListener("keydown", function (e) {
      if (e.key !== "Enter" && e.key !== " ") return;
      var li = e.target && e.target.closest ? e.target.closest("#subTopList li, #subAllList li") : null;
      if (!li || !isLiVisible(li)) return;
      e.preventDefault();
      showPanelFor(li);
    });
  }

  if (changeBtn) {
    changeBtn.addEventListener("click", function () {
      clearSelection();
      if (input) input.focus();
    });
  }

  if (mobileInput) {
    mobileInput.addEventListener("input", function () {
      mobileInput.value = String(mobileInput.value || "").replace(/\D/g, "").slice(0, 10);
      mobileInput.classList.remove("loanrep-loan-input--invalid");
      syncFetchState();
    });
  }
  if (planSelect) {
    planSelect.addEventListener("change", function () {
      planSelect.classList.remove("loanrep-loan-input--invalid");
      syncFetchState();
    });
  }
  if (consentCb) consentCb.addEventListener("change", syncFetchState);

  if (fetchBtn) {
    fetchBtn.addEventListener("click", function () {
      var okMob = isValidMobile(mobileInput ? mobileInput.value : "");
      var okPlan = hasPlan();
      if (mobileInput) mobileInput.classList.toggle("loanrep-loan-input--invalid", !okMob);
      if (planSelect) planSelect.classList.toggle("loanrep-loan-input--invalid", !okPlan);
      if (!okMob || !okPlan) {
        if (fetchStatus) {
          fetchStatus.textContent = !okMob
            ? "Please enter a valid 10-digit mobile number."
            : "Please select a plan.";
        }
        return;
      }
      if (!consentCb || !consentCb.checked) return;
      if (fetchStatus) fetchStatus.textContent = "Bill fetch will connect to your checkout when this flow is integrated.";
    });
  }

  initListA11y();
  syncFetchState();
})();
</script>
</body>

</html>
