<!DOCTYPE html>
<html lang="en">

<%- include("../../components/landing/head") %>

<body class="landing-page service-section-page">
  <div class="landing-page1">
    <div class="sticky-header"><%- include("../../components/landing/header") %></div>
  </div>

  <% var sec = typeof serviceSectionPage !== "undefined" ? serviceSectionPage : {}; %>
  <% var links = Array.isArray(serviceSectionLinks) ? serviceSectionLinks : []; %>

  <section class="section-space service-section-index">
    <div class="container text-start py-4">
      <h1 class="h2 mb-4"><%= sec.name || "Services" %></h1>
      <% if (sec.description) { %>
        <p class="text-muted mb-4"><%= sec.description %></p>
      <% } %>

      <% if (!links.length) { %>
        <p class="text-muted">No services listed for this category yet.</p>
      <% } else { %>
        <ul class="list-unstyled row g-3">
          <% links.forEach(function (link) { %>
            <li class="col-12 col-md-6 col-lg-4">
              <a class="d-block p-3 rounded border border-light shadow-sm text-decoration-none h-100" href="<%= link.href %>">
                <span class="fw-medium text-body"><%= link.title %></span>
              </a>
            </li>
          <% }); %>
        </ul>
      <% } %>
    </div>
  </section>

  <%- include("../../components/landing/footer") %>
  <%- include("../../components/landing/scripts") %>
</body>

</html>
