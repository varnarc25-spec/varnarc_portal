        <div class="electricity-proceed-wrap">
          <button type="button" class="electricity-proceed-btn">Proceed</button>
        </div>

        <section class="electricity-faq" aria-labelledby="electricity-faq-heading">
          <h2 id="electricity-faq-heading">Frequently asked questions</h2>
          <div class="accordion" id="electricityFaq">
            <div class="accordion-item">
              <h3 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#electricityFaq1" aria-expanded="false" aria-controls="electricityFaq1">
                  How can I pay my electricity bill online?
                </button>
              </h3>
              <div id="electricityFaq1" class="accordion-collapse collapse" data-bs-parent="#electricityFaq">
                <div class="accordion-body">
                  Select your electricity distribution company, enter your consumer number or account ID as shown on your bill, verify the bill amount, and pay using UPI, debit/credit card, net banking, or wallet.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <h3 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#electricityFaq2" aria-expanded="false" aria-controls="electricityFaq2">
                  Is it safe to pay electricity bill online?
                </button>
              </h3>
              <div id="electricityFaq2" class="accordion-collapse collapse" data-bs-parent="#electricityFaq">
                <div class="accordion-body">
                  Payments are processed over secure channels. Always confirm you are on the official Varnarc flow, check the biller name and amount before paying, and keep your transaction ID or receipt for your records.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <h3 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#electricityFaq3" aria-expanded="false" aria-controls="electricityFaq3">
                  What if payment is successful but my bill is not updated?
                </button>
              </h3>
              <div id="electricityFaq3" class="accordion-collapse collapse" data-bs-parent="#electricityFaq">
                <div class="accordion-body">
                  Discom systems can take time to reflect payment. Save your receipt and transaction reference. If the discom does not update after the usual window, contact support with those details for reconciliation.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <h3 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#electricityFaq4" aria-expanded="false" aria-controls="electricityFaq4">
                  Can I pay for multiple electricity connections?
                </button>
              </h3>
              <div id="electricityFaq4" class="accordion-collapse collapse" data-bs-parent="#electricityFaq">
                <div class="accordion-body">
                  Yes. Complete payment for one consumer number, then start a new payment for another connection or repeat the flow for additional accounts.
                </div>
              </div>
            </div>
          </div>
        </section>
