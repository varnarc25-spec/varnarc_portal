<%- include('../../../components/landing/footer') %>
<%- include('../../../components/landing/scripts') %>
<script>
(function () {
  var input = document.getElementById("electricityBillerSearch");
  var list = document.getElementById("electricityBillerList");
  if (!input || !list) return;
  input.addEventListener("input", function () {
    var q = String(input.value || "").trim().toLowerCase();
    var items = list.querySelectorAll("li");
    for (var i = 0; i < items.length; i++) {
      var li = items[i];
      var key = (li.getAttribute("data-biller") || li.textContent || "").toLowerCase();
      li.style.display = !q || key.indexOf(q) !== -1 ? "" : "none";
    }
  });
})();
</script>
</body>

</html>
