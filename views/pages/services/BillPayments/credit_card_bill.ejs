<% var pageTitle = 'Credit Card Bill Payment'; %>
<% var pageDescription = 'Pay your credit card bills online on Varnarc — select your card issuer and complete payment securely.'; %>
<%
  var _play = typeof playStoreHref !== 'undefined' && playStoreHref ? playStoreHref : '';
  var _ios = typeof appStoreHref !== 'undefined' && appStoreHref ? appStoreHref : '';
  var downloadHref = _play || _ios || '#';
%>
<!DOCTYPE html>
<html lang="en">

<%- include('../../../components/landing/head') %>
<link rel="stylesheet" href="/assets/css/electricity-page.css" />
<link rel="stylesheet" href="/assets/css/hub-quick-access.css" />
<link rel="stylesheet" href="/assets/css/loan-repayment-page.css" />

<body class="landing-page service-item-page">
  <div class="landing-page1">
    <div class="sticky-header"><%- include('../../../components/landing/header') %></div>
  </div>

  <section class="section-space service-item-section loanrep-service-section">
    <div class="container text-start py-4">
      <div class="loanrep-section-inner" id="ccbSectionInner">
        <div class="loanrep-promo-wrap">
          <div class="loanrep-promo-scroll" tabindex="0" role="region" aria-label="Offers and shortcuts">
            <article class="loanrep-promo-card loanrep-promo-card--accent">
              <p class="loanrep-promo-card__title">Flat 10% cashback on bill payments — eligible categories</p>
              <a href="/services/BillPayments/index" class="loanrep-promo-card__btn">Pay bills</a>
            </article>
            <article class="loanrep-promo-card loanrep-promo-card--muted">
              <p class="loanrep-promo-card__title">Rewards on credit card payments — check your card offer</p>
              <a href="/services/FinancialHub/index" class="loanrep-promo-card__btn">View offers</a>
            </article>
            <article class="loanrep-promo-card loanrep-promo-card--muted">
              <p class="loanrep-promo-card__title">Fast settlement — pay before the due date and avoid late fees</p>
              <a href="/services/BillPayments/credit_card_bill" class="loanrep-promo-card__btn">Pay now</a>
            </article>
            <article class="loanrep-promo-card loanrep-promo-card--muted">
              <p class="loanrep-promo-card__title">DTH &amp; mobile recharge — flat cashback on select packs</p>
              <a href="/services/Recharge/dth" class="loanrep-promo-card__btn">Recharge</a>
            </article>
          </div>
        </div>

        <%- include('../../../components/services/hub/forms/billpayments/credit_card_bill_form', {
          panelSlug: 'credit-card',
          hubEmbed: false
        }) %>

        <section class="loanrep-app-strip mt-4" aria-labelledby="ccb-app-heading">
          <div>
            <h2 id="ccb-app-heading" class="loanrep-app-strip__title">Continue on the app</h2>
            <p class="loanrep-app-strip__sub">Download the app to redeem your rewards</p>
            <% if (_play && _ios) { %>
            <p class="small text-muted mb-0 mt-2">
              <a href="<%= _ios %>" class="link-secondary" rel="noopener noreferrer" target="_blank">App Store</a>
              <span class="text-muted px-1">|</span>
              <a href="<%= _play %>" class="link-secondary" rel="noopener noreferrer" target="_blank">Google Play</a>
            </p>
            <% } %>
          </div>
          <a class="loanrep-download-btn" href="<%= downloadHref %>"<% if (downloadHref !== '#') { %> rel="noopener noreferrer" target="_blank"<% } %> aria-label="Download the Varnarc app">Download</a>
        </section>

        <section class="loanrep-faq" aria-labelledby="ccb-faq-heading">
          <h2 id="ccb-faq-heading">Frequently asked questions</h2>
          <div class="accordion" id="ccbFaq">
            <div class="accordion-item">
              <h3 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#ccbFaq1" aria-expanded="false" aria-controls="ccbFaq1">
                  How do I pay my credit card bill on Varnarc?
                </button>
              </h3>
              <div id="ccbFaq1" class="accordion-collapse collapse" data-bs-parent="#ccbFaq">
                <div class="accordion-body">
                  Choose your card issuer from the list, enter the last four digits of your card and the mobile number registered with the bank for that card, fetch your bill, and pay using your preferred mode.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <h3 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#ccbFaq2" aria-expanded="false" aria-controls="ccbFaq2">
                  When will my credit card payment reflect?
                </button>
              </h3>
              <div id="ccbFaq2" class="accordion-collapse collapse" data-bs-parent="#ccbFaq">
                <div class="accordion-body">
                  Most issuers update your account within a few minutes to 24 hours. Save your transaction ID until the amount appears on your card statement.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <h3 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#ccbFaq3" aria-expanded="false" aria-controls="ccbFaq3">
                  Why can&apos;t I find my bank or card type?
                </button>
              </h3>
              <div id="ccbFaq3" class="accordion-collapse collapse" data-bs-parent="#ccbFaq">
                <div class="accordion-body">
                  Issuers sometimes list corporate or co-brand cards under a different biller name. Try the name printed on your statement, or contact support if your bank is not listed.
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="loanrep-query">
          <p>Still have a query?</p>
          <a class="loanrep-query-card" href="mailto:support@varnarc.com?subject=Credit%20card%20bill%20payment%20support">
            <i class="bi bi-question-circle-fill" aria-hidden="true"></i>
            Raise a request
          </a>
        </section>
      </div>
    </div>
  </section>

<%- include('../../../components/landing/footer') %>
<%- include('../../../components/landing/scripts') %>
<script src="/assets/js/hub-credit-card-wallet.js" defer></script>
</body>

</html>
