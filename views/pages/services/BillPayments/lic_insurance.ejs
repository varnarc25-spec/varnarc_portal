<% var pageTitle = 'LIC / Insurance'; %>
<% var pageDescription = 'Pay insurance premiums online on Varnarc — select your insurer and complete payment securely.'; %>
<%
  var _play = typeof playStoreHref !== 'undefined' && playStoreHref ? playStoreHref : '';
  var _ios = typeof appStoreHref !== 'undefined' && appStoreHref ? appStoreHref : '';
  var downloadHref = _play || _ios || '#';
%>
<!DOCTYPE html>
<html lang="en">

<%- include('../../../components/landing/head') %>
<link rel="stylesheet" href="/assets/css/electricity-page.css" />
<link rel="stylesheet" href="/assets/css/hub-quick-access.css" />
<link rel="stylesheet" href="/assets/css/loan-repayment-page.css" />

<body class="landing-page service-item-page">
  <div class="landing-page1">
    <div class="sticky-header"><%- include('../../../components/landing/header') %></div>
  </div>

  <section class="section-space service-item-section loanrep-service-section">
    <div class="container text-start py-4">
      <div class="loanrep-section-inner" id="licSectionInner">
        <div class="loanrep-promo-wrap">
          <div class="loanrep-promo-scroll" tabindex="0" role="region" aria-label="Offers and shortcuts">
            <article class="loanrep-promo-card loanrep-promo-card--accent">
              <p class="loanrep-promo-card__title">Flat 10% cashback on bill payments — eligible categories</p>
              <a href="/services/BillPayments/index" class="loanrep-promo-card__btn">Pay bills</a>
            </article>
            <article class="loanrep-promo-card loanrep-promo-card--muted">
              <p class="loanrep-promo-card__title">Never miss a premium — renew LIC &amp; life policies on time</p>
              <a href="/services/BillPayments/lic_insurance" class="loanrep-promo-card__btn">Pay premium</a>
            </article>
            <article class="loanrep-promo-card loanrep-promo-card--muted">
              <p class="loanrep-promo-card__title">Pay full premium or a specific amount — your choice</p>
              <a href="/services/BillPayments/lic_insurance" class="loanrep-promo-card__btn">Get started</a>
            </article>
            <article class="loanrep-promo-card loanrep-promo-card--muted">
              <p class="loanrep-promo-card__title">DTH recharge — flat cashback on select packs</p>
              <a href="/services/Recharge/dth" class="loanrep-promo-card__btn">Recharge</a>
            </article>
          </div>
        </div>

        <%- include('../../../components/services/hub/forms/insurance/lic_insurance_form', {
          panelSlug: 'lic-insurance',
          hubEmbed: false
        }) %>

        <section class="loanrep-app-strip mt-4" aria-labelledby="lic-app-heading">
          <div>
            <h2 id="lic-app-heading" class="loanrep-app-strip__title">Continue on the app</h2>
            <p class="loanrep-app-strip__sub">Download the app to redeem your rewards</p>
            <% if (_play && _ios) { %>
            <p class="small text-muted mb-0 mt-2">
              <a href="<%= _ios %>" class="link-secondary" rel="noopener noreferrer" target="_blank">App Store</a>
              <span class="text-muted px-1">|</span>
              <a href="<%= _play %>" class="link-secondary" rel="noopener noreferrer" target="_blank">Google Play</a>
            </p>
            <% } %>
          </div>
          <a class="loanrep-download-btn" href="<%= downloadHref %>"<% if (downloadHref !== '#') { %> rel="noopener noreferrer" target="_blank"<% } %> aria-label="Download the Varnarc app">Download</a>
        </section>

        <section class="loanrep-faq" aria-labelledby="lic-faq-heading">
          <h2 id="lic-faq-heading">Frequently asked questions</h2>
          <div class="accordion" id="licFaq">
            <div class="accordion-item">
              <h3 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#licFaq1" aria-expanded="false" aria-controls="licFaq1">
                  How do I pay my insurance premium on Varnarc?
                </button>
              </h3>
              <div id="licFaq1" class="accordion-collapse collapse" data-bs-parent="#licFaq">
                <div class="accordion-body">
                  Select your insurer, choose how you identify the policy (date of birth and mobile, or policy number and mobile), enter the details shown on your policy document, fetch the bill, and complete payment. Keep your policy number handy for verification.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <h3 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#licFaq2" aria-expanded="false" aria-controls="licFaq2">
                  Can I pay a partial premium amount?
                </button>
              </h3>
              <div id="licFaq2" class="accordion-collapse collapse" data-bs-parent="#licFaq">
                <div class="accordion-body">
                  After fetching your bill, choose <strong>Pay specific amount</strong> and enter the amount you wish to pay (within the limits shown). Insurer rules for partial premiums vary — check your policy or statement after payment.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <h3 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#licFaq3" aria-expanded="false" aria-controls="licFaq3">
                  Why is my policy not found when I fetch the bill?
                </button>
              </h3>
              <div id="licFaq3" class="accordion-collapse collapse" data-bs-parent="#licFaq">
                <div class="accordion-body">
                  Check that the mobile number matches the one registered with the insurer, the policy number has no spaces or typos, and the date of birth format is DD-MM-YYYY exactly as on records. Some group or corporate policies may need to be paid through a different channel — your insurer can confirm.
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="loanrep-query">
          <p>Still have a query?</p>
          <a class="loanrep-query-card" href="mailto:support@varnarc.com?subject=LIC%20%2F%20Insurance%20premium%20support">
            <i class="bi bi-question-circle-fill" aria-hidden="true"></i>
            Raise a request
          </a>
        </section>
      </div>
    </div>
  </section>

<%- include('../../../components/landing/footer') %>
<%- include('../../../components/landing/scripts') %>
<script src="/assets/js/hub-lic-insurance-wallet.js" defer></script>
</body>

</html>
