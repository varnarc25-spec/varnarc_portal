<% var pageTitle = 'Mobile Postpaid Bill Payment'; %>
<% var pageDescription = 'Pay your postpaid mobile bill online on Varnarc — enter your number and complete payment securely.'; %>
<% 
  var _play = typeof playStoreHref !== 'undefined' && playStoreHref ? playStoreHref : '';
  var _ios = typeof appStoreHref !== 'undefined' && appStoreHref ? appStoreHref : '';
  var downloadHref = _play || _ios || '#';
%>
<!DOCTYPE html>
<html lang="en">

<%- include('../../../components/landing/head') %>
<link rel="stylesheet" href="/assets/css/mobile-postpaid-page.css" />

<body class="landing-page service-item-page">
  <div class="landing-page1">
    <div class="sticky-header"><%- include('../../../components/landing/header') %></div>
  </div>

  <section class="section-space service-item-section postpaid-service-section">
    <div class="container text-start py-4">
      <div class="postpaid-section-inner">
        <div class="postpaid-promo-wrap">
          <button type="button" class="postpaid-promo-nav postpaid-promo-nav--prev" id="postpaidPromoPrev" aria-label="Scroll offers left">
            <i class="bi bi-chevron-left" aria-hidden="true"></i>
          </button>
          <div class="postpaid-promo-scroll" id="postpaidPromoScroll" tabindex="0" role="region" aria-label="Offers and shortcuts">
            <article class="postpaid-promo-card postpaid-promo-card--telco">
              <p class="postpaid-promo-card__title">Flat ₹20 cashback on mobile prepaid — any pay mode</p>
              <div class="postpaid-promo-operators" aria-hidden="true">
                <span class="postpaid-pill">Jio</span>
                <span class="postpaid-pill">Vi</span>
              </div>
              <a href="/services/Recharge/mobile_recharge" class="postpaid-promo-card__btn">Recharge now</a>
            </article>
            <article class="postpaid-promo-card postpaid-promo-card--telco">
              <p class="postpaid-promo-card__title">Flat ₹10–₹20 cashback on mobile prepaid via any pay mode</p>
              <div class="postpaid-promo-operators" aria-hidden="true">
                <span class="postpaid-pill">Jio</span>
                <span class="postpaid-pill">Vi</span>
              </div>
              <a href="/services/Recharge/mobile_recharge" class="postpaid-promo-card__btn">Recharge now</a>
            </article>
            <article class="postpaid-promo-card postpaid-promo-card--muted">
              <p class="postpaid-promo-card__title">Flat ₹20 cashback after your 2nd credit card bill payment — any pay mode</p>
              <a href="/services/BillPayments/credit_card_bill" class="postpaid-promo-card__btn">Pay now</a>
            </article>
            <article class="postpaid-promo-card postpaid-promo-card--muted">
              <p class="postpaid-promo-card__title">Insta EMI Card — split spends into easy instalments</p>
              <a href="/services/FinancialHub/index" class="postpaid-promo-card__btn">Get it now</a>
            </article>
          </div>
          <button type="button" class="postpaid-promo-nav postpaid-promo-nav--next" id="postpaidPromoNext" aria-label="Scroll offers right">
            <i class="bi bi-chevron-right" aria-hidden="true"></i>
          </button>
        </div>

        <div class="postpaid-pay-web">
          <h2 class="postpaid-pay-web__title">Pay on Web</h2>
          <label class="postpaid-field-label" for="postpaidMobileInput">Mobile Number</label>
          <input type="tel" id="postpaidMobileInput" class="postpaid-mobile-input" inputmode="numeric" maxlength="10" pattern="[0-9]{10}" autocomplete="tel" placeholder="Please Enter 10-digit mobile number" aria-describedby="postpaidMobileHint" />
          <p id="postpaidMobileHint" class="small text-muted mt-2 mb-0">Enter a valid 10-digit Indian mobile number without country code.</p>
        </div>

        <section class="postpaid-my-number" aria-labelledby="postpaid-my-heading">
          <h2 id="postpaid-my-heading" class="postpaid-my-number__title">My Number</h2>
          <div class="postpaid-saved-row">
            <span class="postpaid-saved-avatar" aria-hidden="true">M</span>
            <span class="postpaid-saved-num">98765 43210</span>
          </div>
          <div class="postpaid-consent">
            <span class="postpaid-consent__mark" aria-hidden="true">V</span>
            <p class="postpaid-consent__text">
              Paying this bill will allow Varnarc to access your current and future bills so that you can conveniently view and pay them.
            </p>
          </div>
        </section>

        <section class="postpaid-app-strip" aria-labelledby="postpaid-app-heading">
          <div>
            <h2 id="postpaid-app-heading" class="postpaid-app-strip__title">Continue on the app</h2>
            <p class="postpaid-app-strip__sub">Download the app to redeem your rewards</p>
            <% if (_play && _ios) { %>
            <p class="small text-muted mb-0 mt-2">
              <a href="<%= _ios %>" class="link-secondary" rel="noopener noreferrer" target="_blank">App Store</a>
              <span class="text-muted px-1">|</span>
              <a href="<%= _play %>" class="link-secondary" rel="noopener noreferrer" target="_blank">Google Play</a>
            </p>
            <% } %>
          </div>
          <a class="postpaid-download-btn" href="<%= downloadHref %>"<% if (downloadHref !== '#') { %> rel="noopener noreferrer" target="_blank"<% } %> aria-label="Download the Varnarc app">Download</a>
        </section>

        <section class="postpaid-faq" aria-labelledby="postpaid-faq-heading">
          <h2 id="postpaid-faq-heading">Frequently asked questions</h2>
          <div class="accordion" id="postpaidFaq">
            <div class="accordion-item">
              <h3 class="accordion-header">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#postpaidFaq1" aria-expanded="false" aria-controls="postpaidFaq1">
                  How do I pay my postpaid mobile bill on Varnarc?
                </button>
              </h3>
              <div id="postpaidFaq1" class="accordion-collapse collapse" data-bs-parent="#postpaidFaq">
                <div class="accordion-body">
                  Enter your 10-digit postpaid number above (or pick a saved number when signed in). We fetch the bill from your operator where supported. Confirm the amount, choose a payment method, and complete the transaction. You will receive a confirmation on screen and by email or SMS when enabled on your account.
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="postpaid-query">
          <p>Still have a query?</p>
          <a class="postpaid-query-card" href="mailto:support@varnarc.com?subject=Mobile%20postpaid%20support">
            <i class="bi bi-question-circle-fill" aria-hidden="true"></i>
            Raise a request
          </a>
        </section>
      </div>
    </div>
  </section>

<%- include('../../../components/landing/footer') %>
<%- include('../../../components/landing/scripts') %>
<script>
(function () {
  var scrollEl = document.getElementById("postpaidPromoScroll");
  var prev = document.getElementById("postpaidPromoPrev");
  var next = document.getElementById("postpaidPromoNext");
  if (scrollEl && prev && next) {
    function step() {
      var card = scrollEl.querySelector(".postpaid-promo-card");
      return card ? Math.min(card.getBoundingClientRect().width + 14, scrollEl.clientWidth * 0.85) : 280;
    }
    prev.addEventListener("click", function () {
      scrollEl.scrollBy({ left: -step(), behavior: "smooth" });
    });
    next.addEventListener("click", function () {
      scrollEl.scrollBy({ left: step(), behavior: "smooth" });
    });
  }
  var mobile = document.getElementById("postpaidMobileInput");
  if (mobile) {
    mobile.addEventListener("input", function () {
      var v = String(mobile.value || "").replace(/\D/g, "").slice(0, 10);
      mobile.value = v;
    });
  }
})();
</script>
</body>

</html>
