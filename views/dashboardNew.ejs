  <!-- <main id="bf-main"> -->
    <section class="bf-hero bf-hero--flush" aria-label="Promotions">
      <div id="bfHeroCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="6000">
        <div class="carousel-indicators">
          <button type="button" data-bs-target="#bfHeroCarousel" data-bs-slide-to="0" class="active" aria-current="true"
            aria-label="Slide 1"></button>
          <button type="button" data-bs-target="#bfHeroCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
          <button type="button" data-bs-target="#bfHeroCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
        </div>
        <div class="carousel-inner">
          <div class="carousel-item active">
            <div class="bf-hero-slide bf-hero-slide--orange bf-hero-slide--tall">
              <div class="bf-hero-slide__content">
                <h2>EMI-friendly shopping &amp; bill pay</h2>
                <p>Browse electronics and appliances on easy terms — plus mobile, DTH, and utility payments in one
                  place.</p>
                <a class="btn btn-light btn-sm fw-bold px-4" href="/services/Recharge/apple_store">Shop EMI
                  store</a>
              </div>
              <div class="bf-hero-slide__art" aria-hidden="true"></div>
            </div>
          </div>
          <div class="carousel-item">
            <div class="bf-hero-slide bf-hero-slide--tall">
              <div class="bf-hero-slide__content">
                <h2>Loans, insurance &amp; investments</h2>
                <p>Explore the financial services available on Varnarc — structured like a full-service marketplace.</p>
                <a class="btn btn-outline-light btn-sm fw-bold px-4" href="/services/BillPayments/index">View
                  services</a>
              </div>
              <div class="bf-hero-slide__art bf-hero-slide__art--navy" aria-hidden="true"></div>
            </div>
          </div>
          <div class="carousel-item">
            <div class="bf-hero-slide bf-hero-slide--warm bf-hero-slide--tall">
              <div class="bf-hero-slide__content">
                <h2>Pay electricity, gas &amp; water</h2>
                <p>Quick bill payment shortcuts with secure checkout.</p>
                <a class="btn btn-dark btn-sm fw-bold px-4" href="/services/BillPayments/electricity">Pay bills</a>
              </div>
              <div class="bf-hero-slide__art bf-hero-slide__art--warm" aria-hidden="true"></div>
            </div>
          </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#bfHeroCarousel" data-bs-slide="prev">
          <span class="carousel-control-prev-icon" aria-hidden="true"></span>
          <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#bfHeroCarousel" data-bs-slide="next">
          <span class="carousel-control-next-icon" aria-hidden="true"></span>
          <span class="visually-hidden">Next</span>
        </button>
      </div>
    </section>

    <section class="bf-strip bf-strip--white" aria-labelledby="bf-cat-heading">
      <div class="bf-container">
        <h2 class="bf-strip__title text-center mb-3" id="bf-cat-heading">Shop by category</h2>
        <div class="bf-tiles bf-tiles--seven">
          <a class="bf-tile" href="/services/BillPayments/loan_repayment"><span class="bf-tile__icon"><i
                class="bi bi-person-badge"></i></span><span>Personal loan</span></a>
          <a class="bf-tile" href="/services/BillPayments/loan_repayment"><span class="bf-tile__icon"><i
                class="bi bi-briefcase"></i></span><span>Business loan</span></a>
          <a class="bf-tile" href="/services/BillPayments/loan_repayment"><span class="bf-tile__icon"><i
                class="bi bi-house-door"></i></span><span>Home loan</span></a>
          <a class="bf-tile" href="/services/BillPayments/credit_card_bill"><span class="bf-tile__icon"><i
                class="bi bi-credit-card-2-front"></i></span><span>EMI card</span></a>
          <a class="bf-tile" href="/services/BillPayments/lic_insurance"><span class="bf-tile__icon"><i
                class="bi bi-shield-plus"></i></span><span>Insurance</span></a>
          <a class="bf-tile" href="/services/BillPayments/portfolio_holdings"><span class="bf-tile__icon"><i
                class="bi bi-safe2"></i></span><span>Fixed deposit</span></a>
          <a class="bf-tile" href="/services/BillPayments/portfolio_holdings"><span class="bf-tile__icon"><i
                class="bi bi-graph-up"></i></span><span>Mutual funds</span></a>
        </div>
      </div>
    </section>

    <%
      var bfStore = '/services/Recharge/apple_store';
      var bfLoan = '/services/BillPayments/loan_repayment';
      var bfIns = '/services/BillPayments/lic_insurance';
      var bfMainBlocks = [
        { kind: 'products', title: 'Mobiles', viewHref: bfStore, items: [
          { title: '5G smartphones', emi: 'From ₹1,499/mo', badge: 'No Cost EMI', href: bfStore, tone: 'blue' },
          { title: 'Camera phones', emi: 'From ₹1,199/mo', badge: null, href: bfStore, tone: 'purple' },
          { title: 'Budget range', emi: 'From ₹499/mo', badge: 'No Cost EMI', href: bfStore, tone: 'teal' },
          { title: 'Premium series', emi: 'From ₹2,999/mo', badge: null, href: bfStore, tone: 'orange' },
          { title: 'Gaming phones', emi: 'From ₹1,899/mo', badge: null, href: bfStore, tone: 'red' },
        ]},
        { kind: 'banner', cls: 'bf-interstitial--brand', linkClass: 'text-white text-decoration-underline',
          htmlBefore: 'Limited-time partner offers on select electronics — ', linkHref: bfStore, linkText: 'Explore EMI store' },
        { kind: 'products', title: 'Laptops', viewHref: bfStore, items: [
          { title: 'Thin & light', emi: 'From ₹2,199/mo', badge: 'No Cost EMI', href: bfStore, tone: 'slate' },
          { title: 'Business laptops', emi: 'From ₹1,899/mo', badge: null, href: bfStore, tone: 'blue' },
          { title: 'Student picks', emi: 'From ₹999/mo', badge: 'No Cost EMI', href: bfStore, tone: 'purple' },
          { title: 'Creators', emi: 'From ₹3,499/mo', badge: null, href: bfStore, tone: 'orange' },
        ]},
        { kind: 'products', title: 'Home appliances', viewHref: bfStore, items: [
          { title: 'Air conditioners', emi: 'From ₹1,299/mo', badge: null, href: bfStore, tone: 'teal' },
          { title: 'Refrigerators', emi: 'From ₹999/mo', badge: 'No Cost EMI', href: bfStore, tone: 'blue' },
          { title: 'Washing machines', emi: 'From ₹899/mo', badge: null, href: bfStore, tone: 'slate' },
          { title: 'Televisions', emi: 'From ₹1,499/mo', badge: 'No Cost EMI', href: bfStore, tone: 'purple' },
          { title: 'Microwaves', emi: 'From ₹349/mo', badge: null, href: bfStore, tone: 'orange' },
        ]},
        { kind: 'products', title: 'Smartwatches', viewHref: bfStore, items: [
          { title: 'Fitness bands', emi: 'From ₹199/mo', badge: null, href: bfStore, tone: 'red' },
          { title: 'Smartwatch Pro', emi: 'From ₹499/mo', badge: 'No Cost EMI', href: bfStore, tone: 'blue' },
          { title: 'Kids trackers', emi: 'From ₹149/mo', badge: null, href: bfStore, tone: 'teal' },
        ]},
        { kind: 'bills' },
        { kind: 'products', title: 'Loans', viewHref: bfLoan, items: [
          { title: 'Gold loan', emi: 'Quick disbursal', badge: null, href: bfLoan, tone: 'gold' },
          { title: 'Doctor loan', emi: 'Tailored rates', badge: null, href: bfLoan, tone: 'slate' },
          { title: 'Personal loan', emi: 'From 12% p.a.', badge: 'Instant', href: bfLoan, tone: 'blue' },
        ]},
        { kind: 'products', title: 'Insurance', viewHref: bfIns, items: [
          { title: 'Health', emi: 'Family plans', badge: null, href: bfIns, tone: 'teal' },
          { title: 'Motor', emi: 'Renew online', badge: null, href: bfIns, tone: 'purple' },
          { title: 'Life', emi: 'Secure future', badge: null, href: bfIns, tone: 'navy' },
        ]},
        { kind: 'banner', cls: 'bf-interstitial--dark', linkClass: 'text-warning text-decoration-none fw-bold',
          htmlBefore: 'Festive sale on home and kitchen — ', linkHref: bfStore, linkText: 'Shop now →' },
        { kind: 'products', title: 'Furniture', viewHref: bfStore, items: [
          { title: 'Sofas', emi: 'From ₹799/mo', badge: 'No Cost EMI', href: bfStore, tone: 'slate' },
          { title: 'Beds', emi: 'From ₹999/mo', badge: null, href: bfStore, tone: 'orange' },
          { title: 'Dining sets', emi: 'From ₹1,199/mo', badge: null, href: bfStore, tone: 'blue' },
        ]},
      ];
    %>
    <% bfMainBlocks.forEach(function (b) { %>
      <% if (b.kind === 'products') { %>
        <section class="bf-row-section">
          <div class="bf-container">
            <div class="bf-row-section__head">
              <h2 class="bf-row-section__title"><%= b.title %></h2>
              <a class="bf-view-all" href="<%= b.viewHref %>">View all</a>
            </div>
            <div class="bf-product-scroller" tabindex="0">
              <% b.items.forEach(function (it) { %>
                <a class="bf-product-card" href="<%= it.href %>">
                  <div class="bf-product-card__img bf-product-card__img--<%= it.tone %>"></div>
                  <% if (it.badge) { %>
                    <span class="bf-product-card__badge"><%= it.badge %></span>
                  <% } %>
                  <h3 class="bf-product-card__title"><%= it.title %></h3>
                  <p class="bf-product-card__emi"><%= it.emi %></p>
                </a>
              <% }); %>
            </div>
          </div>
        </section>
      <% } else if (b.kind === 'banner') { %>
        <div class="bf-interstitial <%= b.cls %>">
          <div class="bf-container text-center text-white">
            <p class="mb-0 fw-semibold"><%= b.htmlBefore %><a class="<%= b.linkClass %>" href="<%= b.linkHref %>"><%= b.linkText %></a></p>
          </div>
        </div>
      <% } else if (b.kind === 'bills') { %>
        <section class="bf-row-section bf-row-section--muted" aria-labelledby="bf-bills-heading">
          <div class="bf-container">
            <div class="bf-row-section__head">
              <h2 class="bf-row-section__title" id="bf-bills-heading">Bill payments</h2>
              <a class="bf-view-all" href="/services/BillPayments/index">View all</a>
            </div>
            <div class="bf-tiles bf-tiles--bills">
              <a class="bf-tile" href="/services/BillPayments/electricity"><span class="bf-tile__icon"><i class="bi bi-lightning-charge"></i></span><span>Electricity</span></a>
              <a class="bf-tile" href="/services/Recharge/mobile_recharge"><span class="bf-tile__icon"><i class="bi bi-phone"></i></span><span>Mobile recharge</span></a>
              <a class="bf-tile" href="/services/Recharge/dth"><span class="bf-tile__icon"><i class="bi bi-tv"></i></span><span>DTH</span></a>
              <a class="bf-tile" href="/services/BillPayments/piped_gas"><span class="bf-tile__icon"><i class="bi bi-fire"></i></span><span>Gas</span></a>
              <a class="bf-tile" href="/services/BillPayments/water"><span class="bf-tile__icon"><i class="bi bi-droplet"></i></span><span>Water</span></a>
              <a class="bf-tile" href="/services/BillPayments/broadband_landline"><span class="bf-tile__icon"><i class="bi bi-wifi"></i></span><span>Broadband</span></a>
            </div>
          </div>
        </section>
      <% } %>
    <% }); %>

    <section class="bf-app-promo" aria-label="Download app">
