        <div class="bf-app-promo__grid">
          <div class="bf-app-promo__phone" aria-hidden="true">
            <div class="bf-app-promo__phone-frame">
              <div class="bf-app-promo__phone-screen"></div>
            </div>
          </div>
          <div class="bf-app-promo__copy">
            <h2>Varnarc app</h2>
            <p>Recharges, bills, EMI shopping, and support — scan to download or get it from your app store.</p>
            <div class="bf-app-promo__stores">
              <a class="bf-store-badge bf-store-badge--play" href="/">Google Play</a>
              <a class="bf-store-badge bf-store-badge--apple" href="/">App Store</a>
            </div>
