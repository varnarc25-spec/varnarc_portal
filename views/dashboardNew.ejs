        <div class="bf-partners__row">
          <% ['Samsung', 'Apple', 'LG', 'Sony', 'Whirlpool', 'HP', 'Dell', 'Bosch'].forEach(function (name) { %>
            <span class="bf-partner-pill"><%= name %></span>
            <% }); %>
        </div>
      </div>
    </section>

    <section class="bf-articles" aria-labelledby="bf-articles-heading">
      <div class="bf-container">
